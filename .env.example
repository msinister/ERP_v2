# Per-tenant database. Each company instance gets its own.
TENANT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/erp_tenant_dev?schema=public"

# Field-level encryption key (AES-256-GCM, base64-encoded 32 bytes).
# Generate via:  node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# Encrypts CustomerDocument EIN/SSN/DL and VendorPaymentMethod payloads.
# Tests inject a deterministic zero-byte key via tests/helpers/setupGlobalEnv.ts;
# production deployments MUST set a real key here.
TENANT_FIELD_ENCRYPTION_KEY=""

# BetterAuth — session token signing secret. Min 32 chars.
# Generate via:  openssl rand -hex 32
BETTER_AUTH_SECRET=""

# BetterAuth — base URL of this instance. Used for cookie domain +
# redirect URL construction. No trailing slash.
# Local dev:  http://localhost:3000
# Production: https://nakedkratom.yourerp.com
BETTER_AUTH_URL="http://localhost:3000"

# First Super Admin bootstrap (read by scripts/create-first-super-admin.ts).
# Password must satisfy the spec policy: >= 8 chars, upper + lower +
# digit + special. NOT read at runtime — only by the bootstrap script.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Super Admin"
