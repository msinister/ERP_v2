 {                                                                                                                                                                                                                                                   "name": "erp",
    "version": "0.1.0",
    "private": true,
    "scripts": {
      "dev": "next dev",
      "build": "next build",
      "start": "next start",
      "lint": "next lint",
      "typecheck": "tsc --noEmit",
      "prisma:generate:tenant": "prisma generate --schema prisma/tenant/schema.prisma",
