      "db:seed:tenant": "tsx --env-file=.env prisma/tenant/seed.ts"
    },
    "dependencies": {
      "next": "^15.0.0",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@prisma/client": "^6.0.0",
      "zod": "^4.0.0"
    },
    "devDependencies": {
      "typescript": "^5.6.0",
      "@types/node": "^22.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "prisma": "^6.0.0",
      "eslint": "^9.0.0",
      "eslint-config-next": "^15.0.0"
    }
  }
