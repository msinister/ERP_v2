generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

enum ProductType {
  SIMPLE
  DROP_SHIP
  SERVICE
}

enum InventoryMovementType {
  ADJUST
  RECEIVE
  CONSUME
  TRANSFER_OUT
  TRANSFER_IN
  RECEIVE_REVERSE
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  CLOSED
  CANCELLED
}

enum ReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

// Add new values when filterability matters. Don't reuse generic
// CREATE / UPDATE / STATUS_CHANGE if a domain-specific action would be
// more useful in audit reports (e.g. "show me every invoice generated
// this month" should not need to filter on entityType).
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  VOID
  REVERSE
  REFUND
  PERMISSION_CHANGE
  CONFIG_CHANGE
  LOGIN
  LOGOUT
  INSUFFICIENT_STOCK_AT_CLOSE
  SENSITIVE_READ
  INVOICE_GENERATED
  PAYMENT_REVERSED
  RMA_STATUS_CHANGE
}

enum InvoiceStatus {
  OPEN // generated, balance > 0
  PARTIAL // some payment applied, balance > 0
  PAID // balance = 0
  VOIDED // credit memo or admin void; no AR impact
}

enum PaymentMethod {
  CREDIT_CARD // Authorize.Net via Kaja (record-only in this slice)
  ACH
  WIRE
  CHECK
  CASH
  MONEY_ORDER
  APPLIED_CREDIT // deducting unapplied credit balance
}

enum PaymentStatus {
  RECORDED
  REVERSED // returned check / failed ACH / chargeback
}

enum CreditMemoStatus {
  DRAFT
  CONFIRMED // posted to GL, applies to AR
  VOIDED
}

enum RmaStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  INSPECTED
  CREDITED // terminal — credit memo issued and confirmed
  REJECTED // terminal — no credit, no inventory effect
}

enum CreditApplicationKind {
  PAYMENT_TO_INVOICE
  CREDIT_TO_INVOICE
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum CustomerType {
  WHOLESALE_REGULAR
  WHOLESALE_PREFERRED
  WHOLESALE_DISTRIBUTOR
  WHOLESALE_MASTER_DISTRIBUTOR
  RETAIL
}

enum CustomerActivityKind {
  AUTO
  MANUAL
}

enum CustomerDocumentKind {
  RESALE_PERMIT
  BUSINESS_LICENSE
  RESALE_CERT
  EIN
  DRIVERS_LICENSE
  SSN
  OTHER
}

enum CommissionBasis {
  REVENUE
  MARGIN
}

enum AddressKind {
  BILLING
  SHIPPING
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  DISPATCHED
  CLOSED
  CANCELLED
}

enum SalesOrderSource {
  STAFF
  PORTAL
  SHOPIFY
}

// Which rule fired in the pricing resolver for a given line. In pilot only
// BASE_PRICE and MANUAL_OVERRIDE are wired; the other rules land alongside
// the customer master + promo + qty-break + cost-plus slices.
enum PriceResolutionRule {
  BASE_PRICE
  MANUAL_OVERRIDE
  CUSTOMER_SPECIFIC
  QTY_BREAK
  TIER_DISCOUNT
  PROMO
  COST_PLUS
}

model Product {
  id               String      @id @default(cuid())
  sku              String      @unique
  name             String
  shortDescription String?
  longDescription  String?
  brand            String?
  category         String?
  type             ProductType @default(SIMPLE)
  tracksInventory  Boolean     @default(true)
  basePrice        Decimal?    @db.Decimal(18, 5)
  weight           Decimal?    @db.Decimal(18, 5)
  lengthDim        Decimal?    @db.Decimal(18, 5)
  widthDim         Decimal?    @db.Decimal(18, 5)
  heightDim        Decimal?    @db.Decimal(18, 5)
  shopifyProductId String?
  active           Boolean     @default(true)
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  variants ProductVariant[]

  @@index([category])
  @@index([brand])
  @@index([shopifyProductId])
}

model ProductVariant {
  id           String    @id @default(cuid())
  productId    String
  sku          String    @unique
  name         String?
  variantGroup String?
  color        String?
  flavor       String?
  size         String?
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product            Product                 @relation(fields: [productId], references: [id])
  inventory          InventoryItem[]
  movements          InventoryMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  receiptLines       ReceiptLine[]
  salesOrderLines    SalesOrderLine[]
  priceOverrides     CustomerPriceOverride[]
  invoiceLines       InvoiceLine[]
  creditMemoLines    CreditMemoLine[]
  fifoLayers         FifoLayer[]

  @@index([productId])
}

model Warehouse {
  id                 String    @id @default(cuid())
  code               String    @unique
  name               String
  active             Boolean   @default(true)
  inventoryAccountId String?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  inventory          InventoryItem[]
  movements          InventoryMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  receipts           Receipt[]
  receiptLines       ReceiptLine[]
  salesOrders        SalesOrder[]
  salesOrderLines    SalesOrderLine[]
  invoices           Invoice[]
  fifoLayers         FifoLayer[]
  inventoryAccount   GlAccount?          @relation(fields: [inventoryAccountId], references: [id])
}

model InventoryItem {
  id          String   @id @default(cuid())
  variantId   String
  warehouseId String
  onHand      Decimal  @default(0) @db.Decimal(18, 5)
  reserved    Decimal  @default(0) @db.Decimal(18, 5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])

  @@unique([variantId, warehouseId])
  @@index([warehouseId])
}

model InventoryMovement {
  id                 String                @id @default(cuid())
  variantId          String
  warehouseId        String
  type               InventoryMovementType
  qty                Decimal               @db.Decimal(18, 5)
  // unitCost: NULL for ADJUST and negative-allocation CONSUME. For RECEIVE
  // (post-Part-1), equals the new FifoLayer's unitCost. For CONSUME (normal),
  // weighted average across consumed layers — per-layer breakdown lives in
  // FifoConsumption rows. Pre-Part-1 RECEIVE rows stay NULL (no backfill).
  unitCost           Decimal?              @db.Decimal(18, 5)
  // True only for CONSUME movements created when negative-inventory flag is
  // ON and stock was insufficient. Forces unitCost=NULL and skips
  // FifoConsumption rows. Future part adds back-fill on subsequent RECEIVE.
  negativeAllocation Boolean               @default(false)
  reference          String?
  transferGroupId    String?
  notes              String?
  createdById        String?
  createdAt          DateTime              @default(now())

  variant          ProductVariant    @relation(fields: [variantId], references: [id])
  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id])
  receiptLine      ReceiptLine?
  fifoLayer        FifoLayer?
  fifoConsumptions FifoConsumption[]

  @@index([variantId, warehouseId, createdAt])
  @@index([type, createdAt])
  @@index([reference])
  @@index([transferGroupId])
}

// FIFO cost layer — created on RECEIVE (via postReceipt), consumed by
// CONSUME movements (oldest receivedDate first). qtyRemaining is a
// denormalized convenience kept in sync via service code; the database
// CHECK constraint enforces qtyRemaining = qtyReceived - qtyConsumed at
// commit time so any drift is caught immediately. unitCost is mutable
// in the late-landed-cost slice (Part 4) but immutable in Part 1.
//
// receivedDate is sourced from Receipt.receivedAt (the business event
// date, not system clock) so user-backdated receipts land in the
// correct FIFO position.
//
// sourceReceiptLineId / sourceMovementId are nullable because future
// parts (RMA returns at original sale's cost, adjustment-gain layers)
// create layers without a Receipt source. Each is @unique to enforce
// 1:1 with its owning Receipt line / RECEIVE movement.
model FifoLayer {
  id                  String    @id @default(cuid())
  variantId           String
  warehouseId         String
  qtyReceived         Decimal   @db.Decimal(18, 5)
  qtyConsumed         Decimal   @default(0) @db.Decimal(18, 5)
  qtyRemaining        Decimal   @db.Decimal(18, 5)
  unitCost            Decimal   @db.Decimal(18, 5)
  receivedDate        DateTime
  sourceReceiptLineId String?   @unique
  sourceMovementId    String?   @unique
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  variant           ProductVariant     @relation(fields: [variantId], references: [id])
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id])
  sourceReceiptLine ReceiptLine?       @relation(fields: [sourceReceiptLineId], references: [id])
  sourceMovement    InventoryMovement? @relation(fields: [sourceMovementId], references: [id])
  consumptions      FifoConsumption[]

  @@index([variantId, warehouseId, receivedDate, id])
  @@index([deletedAt])
}

// Per-layer breakdown of a CONSUME movement. One CONSUME → 1..N
// FifoConsumption rows; SUM(qty) = ABS(InventoryMovement.qty) when
// negativeAllocation = false (test-asserted, not DB-enforced). unitCost
// snapshotted at consume time so Part 4 retroactive layer-cost edits
// don't rewrite history; the retro-COGS engine walks these rows to
// compute deltas.
model FifoConsumption {
  id         String   @id @default(cuid())
  movementId String
  layerId    String
  qty        Decimal  @db.Decimal(18, 5)
  unitCost   Decimal  @db.Decimal(18, 5)
  createdAt  DateTime @default(now())

  movement InventoryMovement @relation(fields: [movementId], references: [id])
  layer    FifoLayer         @relation(fields: [layerId], references: [id])

  @@index([movementId])
  @@index([layerId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  beforeJson Json?
  afterJson  Json?
  reason     String?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// Generic monotonic sequence with optional annual reset. Allocate via
// SELECT ... FOR UPDATE inside a transaction (lib/sequences/sequences.ts).
// Reused by PO numbering, Receipt numbering, and (later) Bill, SO, Invoice.
model Sequence {
  name         String   @id
  currentValue Int      @default(0)
  year         Int?
  updatedAt    DateTime @updatedAt
}

// Minimal vendor stub. Full Vendor master (contacts, payment methods, terms,
// drop-ship/stock flags, commission rate, shadow-customer link, etc.) lands
// in its own slice (see docs/04-vendors-purchasing.md). For now POs and
// Receipts need *something* to FK against — this row holds the bare minimum.
// EXPAND LATER.
model Vendor {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]
  receipts       Receipt[]
}

model PurchaseOrder {
  id                  String              @id @default(cuid())
  number              String              @unique
  vendorId            String
  status              PurchaseOrderStatus @default(DRAFT)
  expectedReceiveDate DateTime?
  currency            String?             @default("USD")
  notes               String?
  createdById         String?
  confirmedAt         DateTime?
  closedAt            DateTime?
  cancelledAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  vendor Vendor              @relation(fields: [vendorId], references: [id])
  lines  PurchaseOrderLine[]

  @@index([vendorId, status])
  @@index([status, expectedReceiveDate])
  @@index([deletedAt])
}

model PurchaseOrderLine {
  id                     String    @id @default(cuid())
  purchaseOrderId        String
  variantId              String
  warehouseId            String
  qtyOrdered             Decimal   @db.Decimal(18, 5)
  qtyReceived            Decimal   @default(0) @db.Decimal(18, 5)
  unitCost               Decimal   @db.Decimal(18, 5)
  vendorSku              String?
  manufacturerPartNumber String?
  notes                  String?
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  receiptLines  ReceiptLine[]

  @@index([purchaseOrderId])
  @@index([variantId])
  @@index([warehouseId])
}

model Receipt {
  id          String        @id @default(cuid())
  number      String        @unique
  vendorId    String
  warehouseId String
  status      ReceiptStatus @default(DRAFT)
  receivedAt  DateTime?
  postedById  String?
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor    Vendor        @relation(fields: [vendorId], references: [id])
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  lines     ReceiptLine[]

  @@index([vendorId, status])
  @@index([warehouseId, receivedAt])
  @@index([deletedAt])
}

// PO ↔ Receipt M:N is realized by: many ReceiptLines pointing at one POLine
// (a PO line can be received in multiple shipments) and a single Receipt
// having ReceiptLines pointing at POLines from different POs (one shipment
// covering multiple POs). No separate join table is needed.
model ReceiptLine {
  id                  String    @id @default(cuid())
  receiptId           String
  purchaseOrderLineId String?
  variantId           String
  warehouseId         String
  qtyReceived         Decimal   @db.Decimal(18, 5)
  unitCost            Decimal   @db.Decimal(18, 5)
  inventoryMovementId String?   @unique
  notes               String?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  receipt           Receipt            @relation(fields: [receiptId], references: [id])
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])
  variant           ProductVariant     @relation(fields: [variantId], references: [id])
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id])
  inventoryMovement InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])
  fifoLayer         FifoLayer?

  @@index([receiptId])
  @@index([purchaseOrderLineId])
  @@index([variantId, warehouseId])
}

model Customer {
  id                String       @id @default(cuid())
  // Auto-issued CUST-YYYY-NNNNN via the Sequence helper. Original stub
  // exposed this as `code` and we keep that name for FK stability.
  code              String       @unique
  // Display name. CITEXT makes the @unique case-insensitive natively.
  // Convention is to add `(City)` suffix on collision — see docs/03-customers.md.
  name              String       @unique @db.Citext
  type              CustomerType @default(WHOLESALE_REGULAR)
  // Required relations. Existing rows are backfilled to UNASSIGNED / NET30
  // before the NOT NULL flip in the migration.
  salesRepId        String
  paymentTermId     String
  // Financial terms.
  creditLimit       Decimal?     @db.Decimal(18, 5) // null = no limit
  arHoldDays        Int? // null = AR hold off
  taxExempt         Boolean      @default(false)
  resaleCertNumber  String?
  // Phone/email may be duplicated across customers (one owner, many stores).
  primaryPhone      String?
  primaryEmail      String?
  // Sticky internal notes — print on every internal document for this customer
  // (per docs/03-customers.md). Distinct from CustomerActivity (timeline) and
  // AuditLog (security/compliance ledger).
  internalNotes     String?
  shopifyCustomerId String? // future Shopify sync
  // Cost-plus % captured for future resolver branch; not wired in this slice.
  costPlusPercent   Decimal?     @db.Decimal(18, 5)
  active            Boolean      @default(true)
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  salesRep       SalesRep                     @relation(fields: [salesRepId], references: [id])
  paymentTerm    PaymentTerm                  @relation(fields: [paymentTermId], references: [id])
  addresses      CustomerAddress[]
  contacts       CustomerContact[]
  priceOverrides CustomerPriceOverride[]
  paymentMethods CustomerPaymentMethod[]
  documents      CustomerDocument[]
  activities     CustomerActivity[]
  tags           CustomerTagAssignment[]
  categories     CustomerCategoryAssignment[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]
  payments       Payment[]
  creditMemos    CreditMemo[]
  rmas           Rma[]

  @@index([type])
  @@index([salesRepId])
  @@index([active, deletedAt])
  @@index([shopifyCustomerId])
}

model SalesOrder {
  id                   String           @id @default(cuid())
  number               String           @unique
  customerId           String
  warehouseId          String
  status               SalesOrderStatus @default(DRAFT)
  source               SalesOrderSource @default(STAFF)
  currency             String?          @default("USD")
  customerPo           String?
  promisedShipDate     DateTime?
  orderDate            DateTime         @default(now())
  // Order-level money. Decimal(18,5); rounding happens at display only.
  // discountPercent and discountAmount are mutually exclusive (Zod-enforced).
  orderDiscountPercent Decimal?         @db.Decimal(18, 5)
  orderDiscountAmount  Decimal?         @db.Decimal(18, 5)
  shippingAmount       Decimal?         @db.Decimal(18, 5)
  handlingAmount       Decimal?         @db.Decimal(18, 5)
  // Free-text ship-to for pilot. The customer master slice will replace
  // this with a proper Address relation; intentionally nullable now.
  shippingAddress      String?
  customerNotes        String?
  internalNotes        String?
  createdById          String?
  // Lifecycle timestamps. Per docs/05-sales-orders.md, picked_at /
  // packed_at / shipping_calculated_at / invoice_generated_at /
  // payment_captured_at are flags-not-statuses and land with the
  // pick/pack/invoice workflows in later slices.
  confirmedAt          DateTime?
  dispatchedAt         DateTime?
  closedAt             DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  deletedAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  customer  Customer         @relation(fields: [customerId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  lines     SalesOrderLine[]
  invoice   Invoice?

  @@index([customerId, status])
  @@index([status, orderDate])
  @@index([warehouseId])
  @@index([deletedAt])
}

model SalesOrderLine {
  id              String              @id @default(cuid())
  salesOrderId    String
  variantId       String
  warehouseId     String
  qtyOrdered      Decimal             @db.Decimal(18, 5)
  qtyReserved     Decimal             @default(0) @db.Decimal(18, 5)
  qtyShipped      Decimal             @default(0) @db.Decimal(18, 5)
  unitPrice       Decimal             @db.Decimal(18, 5)
  priceRule       PriceResolutionRule
  // discountPercent and discountAmount are mutually exclusive (Zod-enforced).
  discountPercent Decimal?            @db.Decimal(18, 5)
  discountAmount  Decimal?            @db.Decimal(18, 5)
  customerNote    String?
  internalNote    String?
  // unitCost snapshot at Closed lands when the costing engine ships
  // (docs/08-gl-costing-reporting.md). Not stored on the line yet.
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  salesOrder SalesOrder     @relation(fields: [salesOrderId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  warehouse  Warehouse      @relation(fields: [warehouseId], references: [id])

  @@index([salesOrderId])
  @@index([variantId, warehouseId])
  @@index([deletedAt])
}

// Admin-managed list. Seeded with Net 30, COD, Prepay, 50% deposit,
// Pay on shipping, Bill later (Net 30) by the migration; the seed file
// re-asserts these on every run.
model PaymentTerm {
  id        String    @id @default(cuid())
  code      String    @unique
  label     String
  netDays   Int? // null for COD/Prepay
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  customers Customer[]
}

// Sales rep — minimal. userId is captured nullable now so the future User
// model can FK in without a migration. Commission rate fields are captured
// here for the commission slice; computation lives elsewhere.
model SalesRep {
  id                String           @id @default(cuid())
  code              String           @unique
  name              String
  email             String?
  active            Boolean          @default(true)
  // Reserved for future User-model FK. Nullable + no @relation defined yet.
  userId            String?
  commissionBasis   CommissionBasis?
  commissionPercent Decimal?         @db.Decimal(18, 5)
  // Group rate placeholder (future SalesRepGroup model).
  groupId           String?
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customers Customer[]

  @@index([userId])
}

model CustomerAddress {
  id         String      @id @default(cuid())
  customerId String
  kind       AddressKind // BILLING or SHIPPING
  // Service layer enforces "exactly one isDefault=true per (customerId, kind)
  // among non-deleted rows" — also guarded by a partial unique index.
  isDefault  Boolean     @default(false)
  label      String? // e.g. "Warehouse", "Storefront"
  line1      String
  line2      String?
  city       String
  region     String // state/province
  postalCode String
  country    String      @default("US")
  // 'attention' is "what to write on the package" (name-only string), not a
  // FK to CustomerContact. Future cleanup: consider FK link in v2.
  attention  String?
  phone      String?
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, kind])
  @@index([customerId, isDefault])
}

model CustomerContact {
  id         String    @id @default(cuid())
  customerId String
  name       String
  // Free-form with autocomplete suggestions: Owner / Buyer / AP / AR / Manager / Shipping
  role       String?
  email      String?
  phone      String?
  mobile     String?
  // Service layer enforces "exactly one isPrimary=true per customer among
  // non-deleted rows" — also guarded by a partial unique index.
  isPrimary  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

// Per-customer per-variant price override. Wins over BASE_PRICE in the
// resolver; loses to MANUAL_OVERRIDE (caller-supplied). CSV import is
// UPSERT-ONLY: rows present in the CSV are inserted/updated; rows absent
// from the CSV are LEFT ALONE — never deleted via the import path.
//
// Uniqueness on (customerId, variantId) is enforced by a partial unique
// index `customerpriceoverride_active_key` that ignores soft-deleted
// rows — created in the price_override_partial_unique migration. Prisma
// can't express partial indices, so the @@unique declaration was
// removed; queries that previously used findUnique on the composite key
// now use findFirst with deletedAt:null in the filter.
model CustomerPriceOverride {
  id         String    @id @default(cuid())
  customerId String
  variantId  String
  unitPrice  Decimal   @db.Decimal(18, 5)
  currency   String?   @default("USD")
  notes      String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer       @relation(fields: [customerId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  // Lookups by (customerId, variantId) are served by the partial unique
  // index `customerpriceoverride_active_key` (declared in raw SQL in
  // the price_override_partial_unique migration). No separate
  // @@index([customerId, variantId]) needed.
  @@index([variantId])
  @@index([deletedAt])
}

// Authorize.Net CIM tokens only. NEVER store PAN, CVV, or anything
// PCI-relevant. Input validation rejects payloads that look like raw card
// numbers. See CLAUDE.md non-negotiable rules.
model CustomerPaymentMethod {
  id                            String    @id @default(cuid())
  customerId                    String
  authorizeNetCustomerProfileId String
  authorizeNetPaymentProfileId  String    @unique
  brand                         String?
  last4                         String?
  expirationMonth               Int?
  expirationYear                Int?
  // Service layer enforces "exactly one isPreferred=true per customer among
  // non-deleted rows" — also guarded by a partial unique index.
  isPreferred                   Boolean   @default(false)
  active                        Boolean   @default(true)
  deletedAt                     DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, isPreferred])
  @@index([expirationYear, expirationMonth])
}

// Document blobs live in DigitalOcean Spaces; this row stores metadata.
// EIN / SSN / DRIVERS_LICENSE values are stored as ciphertext via lib/crypto
// (AES-256-GCM); the cleartext read path emits a SENSITIVE_READ audit row.
model CustomerDocument {
  id               String               @id @default(cuid())
  customerId       String
  kind             CustomerDocumentKind
  // ciphertext (base64) + iv for kinds with a sensitive scalar value.
  encryptedValue   String?
  encryptedValueIv String?
  // For kinds with a file attachment.
  storageKey       String?
  fileName         String?
  contentType      String?
  expiresOn        DateTime?
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, kind])
  @@index([expiresOn])
}

// Customer-scoped business activity log. Distinct from AuditLog: AuditLog is
// the security/compliance ledger (who-did-what across the entire app);
// CustomerActivity is the customer-facing timeline a salesperson reads on
// the customer page. Sensitive customer changes (credit limit, AR hold,
// type, sales rep) write to BOTH — intentional, not redundant.
//
// detailJson conventions:
//   - AUTO entries: { field: string, from: any, to: any }
//   - MANUAL entries: null (the summary string is the whole content)
model CustomerActivity {
  id          String               @id @default(cuid())
  customerId  String
  kind        CustomerActivityKind
  summary     String
  detailJson  Json?
  createdById String?
  createdAt   DateTime             @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
}

// Pre-made list, admin-managed. The `code` column is the stable identifier
// admins reference in scripts/imports (CustomerTag is label-only by design
// — tags are sales-rep ad-hoc, categories are operations-managed lists).
model CustomerCategory {
  id        String    @id @default(cuid())
  code      String    @unique
  label     String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignments CustomerCategoryAssignment[]
}

model CustomerCategoryAssignment {
  customerId String
  categoryId String
  createdAt  DateTime @default(now())

  customer Customer         @relation(fields: [customerId], references: [id])
  category CustomerCategory @relation(fields: [categoryId], references: [id])

  @@id([customerId, categoryId])
  @@index([categoryId])
}

// Free-form, autocomplete-driven. Tag rows are created lazily on first use.
model CustomerTag {
  id        String   @id @default(cuid())
  label     String   @unique @db.Citext
  createdAt DateTime @default(now())

  assignments CustomerTagAssignment[]
}

model CustomerTagAssignment {
  customerId String
  tagId      String
  createdAt  DateTime @default(now())

  customer Customer    @relation(fields: [customerId], references: [id])
  tag      CustomerTag @relation(fields: [tagId], references: [id])

  @@id([customerId, tagId])
  @@index([tagId])
}

// Generic admin-managed key/value settings table. Replaces the
// single-row pattern (RestockingFeeDefault, etc.) — every future
// admin setting (late-fee %, AR-hold default, negative-inventory
// flag, ...) lives here as a typed JSON value validated by a per-key
// Zod schema in the service layer. updatedBy is nullable until
// auth/RBAC ships.
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Invoice generated automatically when a SalesOrder closes.
//
// Numbering: Invoice.number = SalesOrder.number per docs/06-invoicing-ar.md
// (no separate Sequence allocator in pilot). Drop-ship splits where
// child invoices become `{SO}-1` are deferred — when that lands, the
// unique constraint on `salesOrderId` relaxes to a per-SO sequence.
//
// cogsPosted is false until the costing engine slice retroactively
// posts the COGS leg of the SO-close JE. Until then, P&L reports
// overstate net income by the COGS amount of all closed SOs (see
// CLAUDE.md operational notes).
model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  salesOrderId   String        @unique
  customerId     String
  warehouseId    String
  status         InvoiceStatus @default(OPEN)
  // Money snapshot at generation. Immutable except via CreditMemo.
  subtotal       Decimal       @db.Decimal(18, 5)
  orderDiscount  Decimal       @default(0) @db.Decimal(18, 5)
  shippingAmount Decimal       @default(0) @db.Decimal(18, 5)
  handlingAmount Decimal       @default(0) @db.Decimal(18, 5)
  total          Decimal       @db.Decimal(18, 5)
  // Denormalized counters; recompute helpers in the service.
  amountPaid     Decimal       @default(0) @db.Decimal(18, 5)
  amountCredited Decimal       @default(0) @db.Decimal(18, 5)
  currency       String?       @default("USD")
  invoiceDate    DateTime      @default(now())
  customerNotes  String?
  internalNotes  String?
  storedPdfKey   String? // populated on first email; PDF slice deferred
  emailedAt      DateTime?
  voidedAt       DateTime?
  voidReason     String?
  // Flipped to true by the costing engine slice when COGS is retro-posted.
  cogsPosted     Boolean       @default(false)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  salesOrder   SalesOrder          @relation(fields: [salesOrderId], references: [id])
  customer     Customer            @relation(fields: [customerId], references: [id])
  warehouse    Warehouse           @relation(fields: [warehouseId], references: [id])
  lines        InvoiceLine[]
  applications CreditApplication[]
  creditMemos  CreditMemo[]
  rmas         Rma[]

  @@index([customerId, status])
  @@index([status, invoiceDate])
  @@index([cogsPosted])
  @@index([deletedAt])
}

// Snapshot of SO line at close-time. Decoupled from SOLine so SO edits
// after close can never mutate posted invoices.
model InvoiceLine {
  id               String    @id @default(cuid())
  invoiceId        String
  salesOrderLineId String?
  variantId        String
  description      String
  qty              Decimal   @db.Decimal(18, 5)
  unitPrice        Decimal   @db.Decimal(18, 5)
  discountPercent  Decimal?  @db.Decimal(18, 5)
  discountAmount   Decimal?  @db.Decimal(18, 5)
  lineTotal        Decimal   @db.Decimal(18, 5)
  qtyReturned      Decimal   @default(0) @db.Decimal(18, 5)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  invoice         Invoice          @relation(fields: [invoiceId], references: [id])
  variant         ProductVariant   @relation(fields: [variantId], references: [id])
  rmaLines        RmaLine[]
  creditMemoLines CreditMemoLine[]

  @@index([invoiceId])
  @@index([variantId])
}

// A money-receiving event. One Payment can be split across many
// invoices (or none — unapplied) via CreditApplication rows.
model Payment {
  id             String        @id @default(cuid())
  number         String        @unique // PMT-YYYY-NNNNN via Sequence
  customerId     String
  method         PaymentMethod
  status         PaymentStatus @default(RECORDED)
  amount         Decimal       @db.Decimal(18, 5)
  appliedAmount  Decimal       @default(0) @db.Decimal(18, 5)
  currency       String?       @default("USD")
  receivedAt     DateTime      @default(now())
  reference      String?
  notes          String?
  reversedAt     DateTime?
  reversedReason String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer     Customer            @relation(fields: [customerId], references: [id])
  applications CreditApplication[]

  @@index([customerId, receivedAt])
  @@index([status, receivedAt])
}

// Admin-managed list of credit-memo categories. Self-serve in admin
// per spec. affectsInventory tells the credit-memo confirmation path
// whether to emit a structured restock event for the future costing
// engine slice.
model CreditMemoCategory {
  id               String    @id @default(cuid())
  code             String    @unique
  label            String
  affectsInventory Boolean   @default(true)
  active           Boolean   @default(true)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  memos CreditMemo[]
}

model CreditMemo {
  id            String           @id @default(cuid())
  number        String           @unique // CM-YYYY-NNNNN via Sequence
  customerId    String
  invoiceId     String?
  status        CreditMemoStatus @default(DRAFT)
  categoryId    String
  amount        Decimal          @db.Decimal(18, 5)
  restockingFee Decimal          @default(0) @db.Decimal(18, 5)
  netCredit     Decimal          @db.Decimal(18, 5)
  appliedAmount Decimal          @default(0) @db.Decimal(18, 5)
  currency      String?          @default("USD")
  reason        String?
  issuedAt      DateTime?
  voidedAt      DateTime?
  voidReason    String?
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  customer     Customer            @relation(fields: [customerId], references: [id])
  invoice      Invoice?            @relation(fields: [invoiceId], references: [id])
  category     CreditMemoCategory  @relation(fields: [categoryId], references: [id])
  rma          Rma?
  lines        CreditMemoLine[]
  applications CreditApplication[]

  @@index([customerId, status])
  @@index([invoiceId])
}

model CreditMemoLine {
  id            String    @id @default(cuid())
  creditMemoId  String
  invoiceLineId String?
  variantId     String
  qty           Decimal   @db.Decimal(18, 5)
  unitPrice     Decimal   @db.Decimal(18, 5)
  lineTotal     Decimal   @db.Decimal(18, 5)
  description   String
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creditMemo  CreditMemo     @relation(fields: [creditMemoId], references: [id])
  invoiceLine InvoiceLine?   @relation(fields: [invoiceLineId], references: [id])
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([creditMemoId])
}

model Rma {
  id                   String    @id @default(cuid())
  number               String    @unique // RMA-YYYY-NNNNN
  customerId           String
  invoiceId            String
  status               RmaStatus @default(PENDING)
  returnless           Boolean   @default(false)
  reason               String?
  // Restocking-fee policy at RMA creation. Defaults sourced from
  // Setting('restocking_fee_default'); both nullable so an RMA can
  // explicitly carry "no restocking fee" overrides.
  restockingFeePercent Decimal?  @db.Decimal(18, 5)
  restockingFeeFlat    Decimal?  @db.Decimal(18, 5)
  approvedAt           DateTime?
  receivedAt           DateTime?
  inspectedAt          DateTime?
  creditedAt           DateTime?
  rejectedAt           DateTime?
  rejectedReason       String?
  creditMemoId         String?   @unique
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id])
  invoice    Invoice     @relation(fields: [invoiceId], references: [id])
  creditMemo CreditMemo? @relation(fields: [creditMemoId], references: [id])
  lines      RmaLine[]

  @@index([customerId, status])
  @@index([status])
}

model RmaLine {
  id            String    @id @default(cuid())
  rmaId         String
  invoiceLineId String
  qty           Decimal   @db.Decimal(18, 5)
  reason        String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rma         Rma         @relation(fields: [rmaId], references: [id])
  invoiceLine InvoiceLine @relation(fields: [invoiceLineId], references: [id])

  @@index([rmaId])
}

// Single source of truth for "this dollar of payment/credit was
// applied to that dollar of invoice." Reversed apps are kept
// (reversedAt set) so the audit trail survives.
//
// Two partial unique indices on (paymentId, invoiceId) and
// (creditMemoId, invoiceId) — both filtered by reversedAt IS NULL —
// prevent multi-applying the same payment or credit memo to the same
// invoice while live. Created in raw SQL in the migration since
// Prisma can't express partial indices.
model CreditApplication {
  id           String                @id @default(cuid())
  kind         CreditApplicationKind
  paymentId    String?
  creditMemoId String?
  invoiceId    String
  amount       Decimal               @db.Decimal(18, 5)
  appliedAt    DateTime              @default(now())
  appliedById  String?
  reversedAt   DateTime?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  payment    Payment?    @relation(fields: [paymentId], references: [id])
  creditMemo CreditMemo? @relation(fields: [creditMemoId], references: [id])
  invoice    Invoice     @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId, reversedAt])
  @@index([paymentId])
  @@index([creditMemoId])
}

// =========================================================================
// GL stub — minimum needed for the Invoicing & AR slice's auto-JE posts.
//
// Full Chart of Accounts module (hierarchy / parent accounts / period
// close / multi-warehouse inventory accounts / manual JEs / admin
// reversal with closed-period gating) ships in its own slice (Module 7,
// docs/08-gl-costing-reporting.md). This stub is the minimum set of
// shapes the AR auto-posts need to land — same pattern as the Vendor /
// Customer / SalesRep stubs that came before their full slices.
// =========================================================================

model GlAccount {
  id        String      @id @default(cuid())
  // Numeric account code per the spec (1000–9999). Stable identifier
  // for service-layer references (e.g., findByCode('1210')).
  code      String      @unique
  name      String
  type      AccountType
  // Hierarchy / parent-account / sub-account fields land with the GL
  // slice. Stub keeps a flat list.
  active    Boolean     @default(true)
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  journalEntryLines JournalEntryLine[]
  warehouses        Warehouse[]

  @@index([type])
}

model JournalEntry {
  id          String    @id @default(cuid())
  number      String    @unique // JE-YYYY-NNNNN via Sequence
  // Operational source — cross-references the entity that triggered
  // the post. Used by the GL slice for drill-down and by the AR
  // slice's reversal paths to find the JE to reverse.
  entityType  String
  entityId    String
  postedAt    DateTime  @default(now())
  description String
  // Set when the operational entity is voided / payment-reversed /
  // CM-voided. The full GL slice will add admin manual-reverse
  // capability with proper period-close gating.
  reversedAt  DateTime?
  reversedBy  String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines JournalEntryLine[]

  @@index([entityType, entityId])
  @@index([postedAt])
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  // Conventional double-entry: debit and credit are mutually exclusive,
  // both >= 0. The post() helper enforces SUM(debits) = SUM(credits)
  // before insertion.
  debit          Decimal  @default(0) @db.Decimal(18, 5)
  credit         Decimal  @default(0) @db.Decimal(18, 5)
  memo           String?
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      GlAccount    @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}
