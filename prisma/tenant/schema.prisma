generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

enum ProductType {
  SIMPLE
  DROP_SHIP
  SERVICE
  ASSEMBLED
  BUNDLE
}

enum AdjustmentCategory {
  SHORTAGE
  BREAKAGE
  MISSING
  THEFT
  DEFECT
  REJECT
  FOUND_STOCK
  CYCLE_COUNT
  OTHER
}

enum AdjustmentStatus {
  DRAFT
  POSTED
  VOIDED
}

enum InventoryMovementType {
  ADJUST
  RECEIVE
  CONSUME
  TRANSFER_OUT
  TRANSFER_IN
  RECEIVE_REVERSE
  RMA_RETURN
  // BUILD_CONSUME pulls component variants out of inventory during a
  // Work Order completion (FIFO-cost like CONSUME). BUILD_PRODUCE adds
  // the finished good back at the rolled-up build cost (component
  // FIFO cost per unit + per-unit labor). One completion event emits
  // N BUILD_CONSUME rows (one per component) + one BUILD_PRODUCE row
  // for the finished variant.
  BUILD_CONSUME
  BUILD_PRODUCE
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  CLOSED
  CANCELLED
}

enum WorkOrderStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

// Add new values when filterability matters. Don't reuse generic
// CREATE / UPDATE / STATUS_CHANGE if a domain-specific action would be
// more useful in audit reports (e.g. "show me every invoice generated
// this month" should not need to filter on entityType).
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  VOID
  REVERSE
  REFUND
  PERMISSION_CHANGE
  CONFIG_CHANGE
  LOGIN
  LOGOUT
  INSUFFICIENT_STOCK_AT_CLOSE
  SENSITIVE_READ
  INVOICE_GENERATED
  PAYMENT_REVERSED
  RMA_STATUS_CHANGE
  // AP slice. Mirrors INVOICE_GENERATED (system-triggered draft from
  // receipt post) and PAYMENT_REVERSED (filterable AP-side reversal).
  // BILL_CONFIRMED is the GL-posting moment, distinct from CREATE
  // (which only writes the DRAFT row).
  DRAFT_BILL_GENERATED
  BILL_CONFIRMED
  BILL_PAYMENT_RECORDED
  BILL_PAYMENT_REVERSED
  VENDOR_CREDIT_CONFIRMED
  VENDOR_CREDIT_APPLIED
  // GL/period-close slice (phase 9). PERIOD_CLOSED covers both soft and
  // hard close; the audit row's afterJson carries the new status so the
  // distinction is filterable. PERIOD_REOPENED is its own action because
  // reopening is a sensitive operation that warrants distinct reporting.
  // MANUAL_JE_POSTED fires from the assertPostingAllowedTx gate when an
  // override bypasses a HARD_CLOSED period — entityType=FiscalPeriod,
  // afterJson carries the override reason.
  // RECONCILIATION_RUN fires when the slice-D recon checks execute; the
  // afterJson carries the per-check pass/fail summary.
  PERIOD_CLOSED
  PERIOD_REOPENED
  MANUAL_JE_POSTED
  RECONCILIATION_RUN
  // PO shipment-tracking + PO direct-payment slice. PO_PAYMENT_RECORDED /
  // _REVERSED mirror the BILL_PAYMENT_* pair (deposit cash-out + its
  // reversal). PO_PAYMENT_APPLIED fires when a deposit is consumed against
  // a bill (DR 2010 AP / CR 1510 Vendor Deposits) — at receipt time or on
  // void-unwind. Shipment create/update/delete reuse the generic
  // CREATE/UPDATE/DELETE actions (no GL effect — nothing domain-specific
  // to filter on).
  PO_PAYMENT_RECORDED
  PO_PAYMENT_REVERSED
  PO_PAYMENT_APPLIED
}

enum InvoiceStatus {
  OPEN // generated, balance > 0
  PARTIAL // some payment applied, balance > 0
  PAID // balance = 0
  VOIDED // credit memo or admin void; no AR impact
}

enum PaymentMethod {
  CREDIT_CARD // Authorize.Net via Kaja (record-only in this slice)
  ACH
  WIRE
  CHECK
  CASH
  MONEY_ORDER
  APPLIED_CREDIT // deducting unapplied credit balance
  // Payment was collected outside the ERP (Shopify Payments, PayPal,
  // etc.). The recordPayment path still posts a cash-receipt JE against
  // the supplied cashAccountId — typically a Shopify Clearing asset
  // account — so AR balances cleanly even though no money moved inside
  // the ERP itself. Reference field carries the upstream gateway id.
  EXTERNAL
}

enum PaymentStatus {
  RECORDED
  REVERSED // returned check / failed ACH / chargeback
}

enum CreditMemoStatus {
  DRAFT
  CONFIRMED // posted to GL, applies to AR
  VOIDED
}

enum RmaStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  INSPECTED
  CREDITED // terminal — credit memo issued and confirmed
  REJECTED // terminal — no credit, no inventory effect
}

enum CreditApplicationKind {
  PAYMENT_TO_INVOICE
  CREDIT_TO_INVOICE
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum CustomerType {
  WHOLESALE_REGULAR
  WHOLESALE_PREFERRED
  WHOLESALE_DISTRIBUTOR
  WHOLESALE_MASTER_DISTRIBUTOR
  RETAIL
}

enum VendorType {
  STOCK
  DROP_SHIP
  SERVICE
}

// REMIT_TO is "where AP cuts checks" — the canonical AP destination
// per spec. SHIPPING (origin/pickup) and BILLING (mailing) are rare.
enum VendorAddressKind {
  REMIT_TO
  SHIPPING
  BILLING
}

// Vendor payment-method record kind. Per docs/04 line 15, vendors can
// have multiple payment methods on file; the payload (account/routing
// numbers, payee details, card last4) is encrypted at rest. CREDIT_CARD
// here is REFERENCE-ONLY metadata (last4 + brand + exp) — never a full
// PAN. Full PANs go through Authorize.Net CIM, not this table.
enum VendorPaymentMethodKind {
  ACH
  WIRE
  CHECK
  CREDIT_CARD
}

enum CustomerActivityKind {
  AUTO
  MANUAL
}

enum CustomerDocumentKind {
  RESALE_PERMIT
  BUSINESS_LICENSE
  RESALE_CERT
  EIN
  DRIVERS_LICENSE
  SSN
  OTHER
}

enum CommissionBasis {
  REVENUE
  MARGIN
}

enum AddressKind {
  BILLING
  SHIPPING
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  DISPATCHED
  CLOSED
  CANCELLED
}

enum SalesOrderSource {
  STAFF
  PORTAL
  SHOPIFY
}

// Which rule fired in the pricing resolver for a given line. In pilot only
// BASE_PRICE and MANUAL_OVERRIDE are wired; the other rules land alongside
// the customer master + promo + qty-break + cost-plus slices.
enum PriceResolutionRule {
  BASE_PRICE
  MANUAL_OVERRIDE
  CUSTOMER_SPECIFIC
  QTY_BREAK
  TIER_DISCOUNT
  PROMO
  COST_PLUS
  // Set on SalesOrderLine rows produced by exploding a BUNDLE product.
  // The unitPrice is computed by the bundle allocator (basePrice × qty
  // weighting against the bundle total). An inline price edit flips
  // this to MANUAL_OVERRIDE via updateSalesOrderLineFields.
  BUNDLE_ALLOCATED
}

// Allocation method for late landed cost (freight, customs, handling)
// applied retroactively across receipts. Schema declares all four
// values up front so the operationally-supported set can grow without
// an enum migration. The Part 4 service accepts UNIT_COUNT and VALUE;
// WEIGHT (needs ProductVariant.weight) and BOX_COUNT (needs per-line
// box-count input) throw a "deferred to future slice" error until the
// supporting data exists.
enum AllocationMethod {
  UNIT_COUNT
  VALUE
  WEIGHT
  BOX_COUNT
}

// ---------------------------------------------------------------------------
// Bills / AP — phase 8 slice. Vendor-invoice lifecycle.
// docs/07-accounts-payable.md.
//
// Bill lifecycle is intentionally simpler than spec docs/07:33's
// PO-aligned states — the "shipped/in transit/received" phases describe
// the receipt, not the bill. A bill is a financial record: still being
// entered, posted to AP, or cancelled. Payment status is a separate
// dimension, denormalized for filterability.
// ---------------------------------------------------------------------------
enum BillStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum BillPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum VendorCreditStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

// PRODUCT bills carry variantId-bearing lines tied to receipts (DR
// Accrued Receipts on confirm). EXPENSE bills carry expenseAccountId-
// bearing lines (DR <expenseAccount> on confirm). One bill = one source.
enum BillSource {
  PRODUCT
  EXPENSE
}

model Product {
  id                     String      @id @default(cuid())
  sku                    String      @unique
  name                   String
  shortDescription       String?
  longDescription        String?
  brand                  String?
  category               String?
  // Manufacturer part number — a product-level catalog attribute. Distinct
  // from PurchaseOrderLine.manufacturerPartNumber (which is per-PO-line);
  // this is the canonical MPN shown on the product list + detail.
  manufacturerPartNumber String?
  type                   ProductType @default(SIMPLE)
  tracksInventory        Boolean     @default(true)
  basePrice              Decimal?    @db.Decimal(18, 5)
  weight                 Decimal?    @db.Decimal(18, 5)
  weightUnit             String?     @default("lb")
  lengthDim              Decimal?    @db.Decimal(18, 5)
  widthDim               Decimal?    @db.Decimal(18, 5)
  heightDim              Decimal?    @db.Decimal(18, 5)
  dimensionUnit          String?     @default("in")
  // Trade-compliance master data (no inventory impact). Free-text by
  // design: countryOfOrigin is an ISO-ish label, hsCode is the
  // Harmonized System tariff code. hazmat flags dangerous-goods
  // handling for shipping/labeling downstream.
  countryOfOrigin        String?
  hsCode                 String?
  hazmat                 Boolean     @default(false)
  // Stamped on every successful upsertProductFromShopify run (primary
  // variant only) so the detail page can show "Synced from Shopify ·
  // {when}" without a join. All Shopify product/variant IDs live in
  // ProductShopifyVariant (junction); a product can link to multiple
  // Shopify listings — both primary + deal/bundle secondaries within a
  // store, and across multiple ShopifyStores.
  shopifySyncedAt        DateTime?
  active                 Boolean     @default(true)
  // Flat-dollar labor cost rolled into the cost of every finished
  // unit produced from this product's BOM. Optional — null = no
  // labor charge. Only meaningful when the product has BOM lines
  // (type IN (SIMPLE, ASSEMBLED)). Stored at the same Decimal
  // precision as unit costs so the build cost rollup stays exact.
  bomLaborCost           Decimal?    @db.Decimal(18, 5)
  deletedAt              DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  variants                    ProductVariant[]
  shopifyVariants             ProductShopifyVariant[]
  images                      ProductImage[]
  tags                        ProductTag[]
  bomLines                    BomLine[]               @relation("ProductBomLines")
  workOrders                  WorkOrder[]             @relation("WorkOrderProduct")
  // Back-relations for the bundle-explode flow: SalesOrderLine and
  // InvoiceLine rows that point at this BUNDLE product as their source.
  bundleSourceSalesOrderLines SalesOrderLine[]        @relation("BundleSourceSalesOrderLines")
  bundleSourceInvoiceLines    InvoiceLine[]           @relation("BundleSourceInvoiceLines")

  @@index([category])
  @@index([brand])
}

// Product-level image gallery. Multiple images per product with one
// `isPrimary` marker that thumbnail surfaces resolve to. Storage
// destinations (currently a local-disk stub; Spaces later) write
// the URL into `url` — the schema doesn't care which provider
// produced it. Soft-delete (deletedAt) preserves history; live
// queries filter deletedAt: null.
//
// One-primary-per-product is enforced at the service layer (set
// primary atomically demotes any other primary). A partial unique
// index could enforce it at the DB but would complicate the
// "swap primary" flow — service-layer enforcement is the spec
// precedent here (customer payment methods, etc.).
model ProductImage {
  id             String    @id @default(cuid())
  productId      String
  url            String
  isPrimary      Boolean   @default(false)
  sortOrder      Int       @default(0)
  altText        String?
  // Shopify-side image id when this row was synced from Shopify. Lets
  // re-syncs upsert in place instead of duplicating rows, and lets
  // image-removal sweeps target only Shopify-sourced images (operator-
  // added images stay regardless of what's in Shopify).
  shopifyImageId String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, sortOrder])
  @@index([productId, isPrimary])
  @@index([deletedAt])
  @@index([shopifyImageId])
}

// One row per (ERP product, ShopifyStore, Shopify variant) tuple. An ERP
// product can link to multiple Shopify listings — within a store the
// primary listing (isPrimary=true) drives catalog fields (name, images,
// tags); secondary rows represent deal/bundle/mix-and-match Shopify
// products whose variants map to the same physical SKU. The same product
// can also appear across multiple stores, each with its own primary +
// secondary rows.
//
// shopifyVariantId is unique PER STORE (composite unique), not globally —
// different Shopify tenants have independent id namespaces. inventoryItemId
// is cached on first push so subsequent pushes skip the lookup hop.
//
// When the ERP pushes inventory to Shopify it fans out to every row for
// the product, grouped by store; stores with inventoryPushEnabled=false
// are skipped.
model ProductShopifyVariant {
  id               String   @id @default(cuid())
  productId        String
  shopifyStoreId   String
  shopifyProductId String
  shopifyVariantId String
  // Shopify inventory_item_id — cached lazily on first push so we can
  // call /inventory_levels/set.json without re-fetching the variant.
  inventoryItemId  String?
  isPrimary        Boolean  @default(false)
  syncedAt         DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product      @relation(fields: [productId], references: [id])
  store   ShopifyStore @relation(fields: [shopifyStoreId], references: [id])

  @@unique([shopifyStoreId, shopifyVariantId])
  @@index([productId])
  @@index([shopifyStoreId, shopifyProductId])
}

// One ERP instance can connect to many Shopify stores. Each store carries
// its own credentials (encrypted), sync flags, last-run results, and the
// set of routing rules that decide which ERP products are eligible to
// sync to / push inventory to it. Soft-delete (deletedAt) preserves
// history; junction rows for an archived store remain but pushes are
// gated by `active && inventoryPushEnabled`.
//
// Secrets are AES-256-GCM encrypted via lib/crypto and stored as Json
// {ciphertext, iv} — same pattern as the legacy Setting blob.
model ShopifyStore {
  id                     String        @id @default(cuid())
  name                   String
  storeUrl               String        @unique
  // {ciphertext, iv} per lib/crypto contract. Nullable so a store row can
  // be created (UI scaffolding) before secrets are pasted.
  accessToken            Json?
  webhookSecret          Json?
  // Product-direction sync (Shopify → ERP product upsert + ERP → Shopify
  // product create/update). The flag is intentionally named `syncEnabled`
  // for back-compat with the slice-A migration; it gates the product
  // webhook auth path and the full-sync / push-products buttons.
  syncEnabled            Boolean       @default(false)
  inventoryPushEnabled   Boolean       @default(false)
  // Order-direction sync (Shopify → ERP order import). Distinct gate
  // from `syncEnabled` so an operator can run product sync without ever
  // pulling orders, or vice versa. When false, /sync-orders short-circuits
  // and the order webhooks return 200 disabled.
  orderSyncEnabled       Boolean       @default(false)
  // Shopify Location id (REST) that inventory is pushed against. Required
  // for inventory_levels/set; if null, pushes for this store short-circuit
  // with a clear error.
  shopifyLocationId      String?
  // Per-store defaults applied when importing orders. Used by the order
  // sync service to seed SalesOrder.warehouseId, Customer.salesRepId /
  // .paymentTermId / .type when auto-creating a customer from a Shopify
  // payload. Nullable on the model (legacy rows pre-date these); the
  // service throws "store not configured for order sync" when an import
  // fires against a store that's missing any of them.
  defaultWarehouseId     String?
  defaultSalesRepId      String?
  defaultPaymentTermId   String?
  defaultCustomerType    CustomerType?
  lastProductSyncAt      DateTime?
  lastInventoryPushAt    DateTime?
  lastOrderSyncAt        DateTime?
  // Last-run summaries — Json blobs mirror the legacy StoredSyncRun /
  // StoredPushRun shape. Surfaced on the per-store admin tile.
  lastSyncResult         Json?
  lastPushResult         Json?
  lastOrderSyncResult    Json?
  // Webhook subscription ids returned by Shopify on register. Shape:
  // Record<topic, subscriptionId>. Lets the admin UI show "currently
  // registered" without re-querying Shopify.
  webhookSubscriptionIds Json?
  sortOrder              Int           @default(0)
  active                 Boolean       @default(true)
  deletedAt              DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  createdBy              String?
  updatedBy              String?

  rules                ShopifyStoreRule[]
  productVariants      ProductShopifyVariant[]
  salesOrders          SalesOrder[]
  pendingOrderReviews  PendingOrderReview[]
  shopifyCustomerLinks ShopifyCustomerLink[]
  defaultWarehouse    Warehouse?              @relation("ShopifyStoreDefaultWarehouse", fields: [defaultWarehouseId], references: [id])
  defaultSalesRep     SalesRep?               @relation("ShopifyStoreDefaultSalesRep", fields: [defaultSalesRepId], references: [id])
  defaultPaymentTerm  PaymentTerm?            @relation("ShopifyStoreDefaultPaymentTerm", fields: [defaultPaymentTermId], references: [id])

  @@index([active])
  @@index([deletedAt])
  @@index([orderSyncEnabled])
}

// Routing-rule rows per store. Evaluated together to decide whether a
// given product is eligible to sync into this store.
//
// Semantics (see shopifyStoreRules.productMatchesStore):
//   - No rules    → no products eligible (explicit opt-in required).
//   - INCLUDE_ALL → every active product eligible.
//   - INCLUDE_X   → additive (union). A product matching ANY include is in.
//   - EXCLUDE_X   → wins over includes. A product matching ANY exclude is out.
//
// Vendor matching uses the product's primary VendorProduct (isPrimary=true
// on any variant). Category matches Product.category exactly (case-
// insensitive). Tag matches any name on ProductTag for the product.
model ShopifyStoreRule {
  id             String               @id @default(cuid())
  shopifyStoreId String
  ruleType       ShopifyStoreRuleType
  // Empty string for INCLUDE_ALL; vendor name / category / tag name for the
  // typed variants. Stored as-typed by the operator; matching is case-
  // insensitive at evaluation time.
  value          String               @default("")
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  createdBy      String?
  updatedBy      String?

  store ShopifyStore @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)

  @@index([shopifyStoreId, sortOrder])
}

enum ShopifyStoreRuleType {
  INCLUDE_ALL
  INCLUDE_VENDOR
  EXCLUDE_VENDOR
  INCLUDE_CATEGORY
  EXCLUDE_CATEGORY
  INCLUDE_TAG
  EXCLUDE_TAG
}

// Store-scoped Shopify customer → ERP customer mapping. Replaces the old
// global Customer.shopifyCustomerId scalar so the same Shopify customer
// (or email) can map to different ERP billing accounts per store — the
// standard pattern for multi-location B2B accounts that share one email.
// PK is (shopifyStoreId, shopifyCustomerId): one Shopify customer can only
// map to one ERP customer per store, but the same ERP customer can have
// links across multiple stores.
model ShopifyCustomerLink {
  shopifyStoreId    String
  shopifyCustomerId String
  customerId        String
  createdAt         DateTime @default(now())

  store    ShopifyStore @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([shopifyStoreId, shopifyCustomerId])
  @@index([customerId])
}

model ProductVariant {
  id           String    @id @default(cuid())
  productId    String
  sku          String    @unique
  name         String?
  variantGroup String?
  color        String?
  flavor       String?
  size         String?
  // Optional variant-specific image. When set, ProductThumbnail
  // prefers this over the parent product's primary image — lets
  // operators swap thumbnails per variant (different color jars,
  // different flavor labels) without giving variants their own
  // gallery. Stored as a single URL; multi-image variants are
  // deferred (spec).
  imageUrl     String?
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product                  Product                   @relation(fields: [productId], references: [id])
  inventory                InventoryItem[]
  movements                InventoryMovement[]
  purchaseOrderLines       PurchaseOrderLine[]
  receiptLines             ReceiptLine[]
  salesOrderLines          SalesOrderLine[]
  priceOverrides           CustomerPriceOverride[]
  invoiceLines             InvoiceLine[]
  creditMemoLines          CreditMemoLine[]
  fifoLayers               FifoLayer[]
  vendorProducts           VendorProduct[]
  billLines                BillLine[]
  inventoryAdjustmentLines InventoryAdjustmentLine[]
  bomComponentUsage        BomLine[]                 @relation("BomLineComponent")
  // Built as the finished variant on a Work Order.
  workOrdersBuilt          WorkOrder[]               @relation("WorkOrderFinishedVariant")
  // Consumed as a component in a Work Order's snapshot BOM.
  workOrderComponents      WorkOrderComponent[]      @relation("WorkOrderComponentVariant")

  @@index([productId])
}

// BOM (Bill of Materials) line — defines one component required to
// build one finished unit of `parentProduct`. The BOM is the
// collection of BomLine rows for a given parent product; there's no
// separate Bom header table (laborCost lives on Product). A BOM is a
// template — actual builds (Work Orders) reference the template at
// build time and snapshot the cost rollup into FIFO layers.
//
// componentVariantId points to a ProductVariant (not Product) so
// component selection has the same granularity as POs / SOs. Duplicate
// (parent, component) rows are allowed at the DB level so the operator
// can split the same component across multiple steps with different
// notes — the UI warns but doesn't block.
//
// sortOrder gives the BOM table a stable, operator-controlled display
// order (parallels ProductImage.sortOrder). Soft-delete via deletedAt
// + service-layer wholesale-replace mirrors the PO line pattern.
model BomLine {
  id                 String    @id @default(cuid())
  parentProductId    String
  componentVariantId String
  qtyRequired        Decimal   @db.Decimal(18, 5)
  sortOrder          Int       @default(0)
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  parentProduct    Product        @relation("ProductBomLines", fields: [parentProductId], references: [id])
  componentVariant ProductVariant @relation("BomLineComponent", fields: [componentVariantId], references: [id])

  @@index([parentProductId, sortOrder])
  @@index([componentVariantId])
  @@index([deletedAt])
}

model Warehouse {
  id                 String    @id @default(cuid())
  code               String    @unique
  name               String
  active             Boolean   @default(true)
  inventoryAccountId String?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  inventory            InventoryItem[]
  movements            InventoryMovement[]
  purchaseOrderLines   PurchaseOrderLine[]
  receipts             Receipt[]
  receiptLines         ReceiptLine[]
  salesOrders          SalesOrder[]
  salesOrderLines      SalesOrderLine[]
  invoices             Invoice[]
  fifoLayers           FifoLayer[]
  users                User[]
  workOrders           WorkOrder[]
  inventoryAdjustments InventoryAdjustment[]
  inventoryAccount     GlAccount?            @relation(fields: [inventoryAccountId], references: [id])
  shopifyStoreDefaults ShopifyStore[]        @relation("ShopifyStoreDefaultWarehouse")
}

model InventoryItem {
  id          String   @id @default(cuid())
  variantId   String
  warehouseId String
  onHand      Decimal  @default(0) @db.Decimal(18, 5)
  reserved    Decimal  @default(0) @db.Decimal(18, 5)
  // Free-text bin/shelf location for this variant in this warehouse
  // (e.g. "A-12-3", "Shelf B Row 4"). Operator-maintained; no inventory
  // impact.
  binLocation String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])

  @@unique([variantId, warehouseId])
  @@index([warehouseId])
}

model InventoryMovement {
  id                 String                @id @default(cuid())
  variantId          String
  warehouseId        String
  type               InventoryMovementType
  qty                Decimal               @db.Decimal(18, 5)
  // unitCost: NULL for ADJUST and negative-allocation CONSUME. For RECEIVE
  // (post-Part-1), equals the new FifoLayer's unitCost. For CONSUME (normal),
  // weighted average across consumed layers — per-layer breakdown lives in
  // FifoConsumption rows. Pre-Part-1 RECEIVE rows stay NULL (no backfill).
  unitCost           Decimal?              @db.Decimal(18, 5)
  // True only for CONSUME movements created when negative-inventory flag is
  // ON and stock was insufficient. Forces unitCost=NULL and skips
  // FifoConsumption rows. Future part adds back-fill on subsequent RECEIVE.
  negativeAllocation Boolean               @default(false)
  reference          String?
  transferGroupId    String?
  notes              String?
  createdById        String?
  createdAt          DateTime              @default(now())

  variant          ProductVariant    @relation(fields: [variantId], references: [id])
  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id])
  receiptLine      ReceiptLine?
  fifoLayer        FifoLayer?
  fifoConsumptions FifoConsumption[]
  salesOrderLine   SalesOrderLine?

  @@index([variantId, warehouseId, createdAt])
  @@index([type, createdAt])
  @@index([reference])
  @@index([transferGroupId])
}

// FIFO cost layer — created on RECEIVE (via postReceipt), consumed by
// CONSUME movements (oldest receivedDate first). qtyRemaining is a
// denormalized convenience kept in sync via service code; the database
// CHECK constraint enforces qtyRemaining = qtyReceived - qtyConsumed at
// commit time so any drift is caught immediately. unitCost is mutable
// in the late-landed-cost slice (Part 4) but immutable in Part 1.
//
// receivedDate is sourced from Receipt.receivedAt (the business event
// date, not system clock) so user-backdated receipts land in the
// correct FIFO position.
//
// sourceReceiptLineId / sourceMovementId are nullable because future
// parts (RMA returns at original sale's cost, adjustment-gain layers)
// create layers without a Receipt source. Each is @unique to enforce
// 1:1 with its owning Receipt line / RECEIVE movement.
model FifoLayer {
  id                  String    @id @default(cuid())
  variantId           String
  warehouseId         String
  qtyReceived         Decimal   @db.Decimal(18, 5)
  qtyConsumed         Decimal   @default(0) @db.Decimal(18, 5)
  qtyRemaining        Decimal   @db.Decimal(18, 5)
  unitCost            Decimal   @db.Decimal(18, 5)
  receivedDate        DateTime
  sourceReceiptLineId String?   @unique
  sourceMovementId    String?   @unique
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  variant                   ProductVariant             @relation(fields: [variantId], references: [id])
  warehouse                 Warehouse                  @relation(fields: [warehouseId], references: [id])
  sourceReceiptLine         ReceiptLine?               @relation(fields: [sourceReceiptLineId], references: [id])
  sourceMovement            InventoryMovement?         @relation(fields: [sourceMovementId], references: [id])
  consumptions              FifoConsumption[]
  // Back-relation: rows in LandedCostAllocationLine that mutated this
  // layer's unitCost. One layer can be touched by multiple non-reversed
  // allocations over its lifetime (e.g., freight bill + later customs
  // bill). reverseLandedCostAllocation walks these to restore originals.
  landedCostAllocationLines LandedCostAllocationLine[]
  // Back-relation: Work Order completion event that produced this
  // layer (BUILD_PRODUCE path). Set only on layers created by
  // completeWorkOrder; null for layers from receipts / returns.
  workOrderCompletion       WorkOrderCompletion?

  @@index([variantId, warehouseId, receivedDate, id])
  @@index([deletedAt])
}

// Per-layer breakdown of a CONSUME movement. One CONSUME → 1..N
// FifoConsumption rows; SUM(qty) = ABS(InventoryMovement.qty) when
// negativeAllocation = false (test-asserted, not DB-enforced).
//
// unitCost is the cost-at-consume snapshot. Mutability rule (revised in
// Part 4):
//   - MUTABLE before the linked invoice has cogsPosted=true (GL hasn't
//     realized this consume yet, so the snapshot is the working value
//     for the eventual COGS post; applyLandedCostToReceipts updates it
//     in place so Part 3's deferred cogsPosting picks up the corrected
//     cost in one shot — no separate adjustment JE needed).
//   - IMMUTABLE after cogsPosted=true (history preserves what was
//     actually posted to GL; subsequent cost changes flow through
//     adjustment JEs posted by applyLandedCostToReceipts, NOT through
//     snapshot rewrites).
// Manual / transfer CONSUME movements with no SOLine link skip the
// snapshot mutation and post no JE; the layer's unitCost still moves.
model FifoConsumption {
  id         String   @id @default(cuid())
  movementId String
  layerId    String
  qty        Decimal  @db.Decimal(18, 5)
  unitCost   Decimal  @db.Decimal(18, 5)
  createdAt  DateTime @default(now())

  movement InventoryMovement @relation(fields: [movementId], references: [id])
  layer    FifoLayer         @relation(fields: [layerId], references: [id])

  @@index([movementId])
  @@index([layerId])
}

model AuditLog {
  id         String      @id @default(cuid())
  // No FK to User — audit log is append-only and must survive a user
  // hard-delete. Keep the id-as-string reference instead of a relation.
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  beforeJson Json?
  afterJson  Json?
  reason     String?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// =========================================================================
// Auth tables — owned by BetterAuth (better-auth v1.6.x).
//
// IMPORTANT: do NOT rename columns or drop fields without consulting
// BetterAuth's schema docs — the prisma adapter looks them up by name.
// ERP-specific extensions live on User as additional columns; they do
// not interfere with BetterAuth's reads. See src/lib/auth/auth.ts for
// the matching `additionalFields` declaration.
//
// RBAC model: a Super Admin boolean (bypasses all checks) PLUS optional
// custom Roles. A Role carries a sparse JSON permission map; a User
// references at most one Role via `roleId`. Super Admin has no role and
// needs none — `isSuperAdmin` short-circuits every permission check. See
// src/lib/permissions/ for the catalog + check/scope helpers.
// =========================================================================

// Custom role — a named bundle of granular permissions. `permissions` is
// a sparse JSON map of PermissionKey -> true (absent key = not granted),
// validated against src/lib/permissions/constants.ts in the service layer.
// We store JSON rather than a normalized RolePermission table by design:
// the permission set is small, always read whole, and edited as one form.
// Soft-delete refuses while any User still references the role.
model Role {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  permissions Json      @default("{}")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users User[]

  @@index([deletedAt])
}

model User {
  // BetterAuth core fields ------------------------------------------------
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      Boolean   @default(false)
  name               String
  image              String?
  // ERP additional fields (declared in auth.ts under user.additionalFields)
  phone              String?
  title              String?
  department         String?
  warehouseId        String?
  salesRepId         String?   @unique
  // Optional custom role. NULL for Super Admins (they bypass checks) and
  // for users granted no role yet. Permission checks read role.permissions
  // via lib/permissions/loadActor.
  roleId             String?
  // Super Admin bypasses every permission + scope check. Distinct from a
  // role: it's an all-access flag, not a permission bundle.
  isSuperAdmin       Boolean   @default(false)
  // Disabling a user prevents login but preserves audit trail. Distinct
  // from soft-delete (deletedAt) — a disabled-but-not-deleted account
  // can be re-enabled without rehydrating relationships.
  enabled            Boolean   @default(true)
  forcePasswordReset Boolean   @default(false)
  lastLoginAt        DateTime?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  salesRep  SalesRep?  @relation(fields: [salesRepId], references: [id])
  role      Role?      @relation(fields: [roleId], references: [id])
  sessions  Session[]
  accounts  Account[]

  @@index([enabled, deletedAt])
  @@index([warehouseId])
  @@index([roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  // Per-provider credential record. For email+password BetterAuth uses
  // providerId="credential" and stores the password hash in `password`.
  // Hashing is handled by BetterAuth (Scrypt by default) — never store
  // plaintext here.
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  password              String?
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  idToken               String?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  // Email-verification tokens, password-reset tokens, etc. (all of which
  // are deferred for pilot but the table is required by BetterAuth so it
  // can issue tokens for whatever flows we later turn on).
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([expiresAt])
}

// Generic monotonic sequence with optional annual reset. Allocate via
// SELECT ... FOR UPDATE inside a transaction (lib/sequences/sequences.ts).
// Reused by PO numbering, Receipt numbering, and (later) Bill, SO, Invoice.
model Sequence {
  name         String   @id
  currentValue Int      @default(0)
  year         Int?
  updatedAt    DateTime @updatedAt
}

// Minimal vendor stub. Full Vendor master (contacts, payment methods, terms,
// drop-ship/stock flags, commission rate, shadow-customer link, etc.) lands
// in its own slice (see docs/04-vendors-purchasing.md). For now POs and
// Receipts need *something* to FK against — this row holds the bare minimum.
// EXPAND LATER.
// Vendor master. Pilot scope: stock + service vendors used for PO entry
// and AP. Drop-ship (commission model) gets schema room here
// (`defaultCommissionRate`) but no service logic — see
// docs/04-vendors-purchasing.md for the deferred drop-ship slice.
//
// `paymentTermId` is nullable on the model so legacy upsert-stub
// fixtures keep working; the service create schema requires it. Same
// pattern as `defaultCurrency`.
model Vendor {
  id                    String     @id @default(cuid())
  code                  String     @unique
  name                  String
  type                  VendorType @default(STOCK)
  active                Boolean    @default(true)
  paymentTermId         String?
  defaultCurrency       String?    @default("USD")
  // Warning-level threshold for PO entry; null defers to a future global
  // setting. Not block.
  minimumOrderAmount    Decimal?   @db.Decimal(18, 5)
  // Per-vendor cost-change threshold (% of prior cost). Null = use
  // global default. Informational alert, not block.
  costChangeAlertPct    Decimal?   @db.Decimal(18, 5)
  notes                 String?
  // Drop-ship schema room. Service logic lands in the deferred
  // drop-ship slice; no readers in pilot.
  defaultCommissionRate Decimal?   @db.Decimal(18, 5)
  deletedAt             DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  paymentTerm    PaymentTerm?          @relation(fields: [paymentTermId], references: [id])
  contacts       VendorContact[]
  addresses      VendorAddress[]
  products       VendorProduct[]
  paymentMethods VendorPaymentMethod[]
  purchaseOrders PurchaseOrder[]
  receipts       Receipt[]
  bills          Bill[]
  billPayments   BillPayment[]
  vendorCredits  VendorCredit[]
  poPayments     PoPayment[]

  @@index([type])
  @@index([active, deletedAt])
}

model PurchaseOrder {
  id                  String              @id @default(cuid())
  number              String              @unique
  vendorId            String
  status              PurchaseOrderStatus @default(DRAFT)
  expectedReceiveDate DateTime?
  currency            String?             @default("USD")
  notes               String?
  createdById         String?
  confirmedAt         DateTime?
  closedAt            DateTime?
  // Free-text reason supplied when an operator manually closes a PO
  // before it's fully received (short shipment, vendor cancellation,
  // damaged goods). NULL when the PO closed via the auto-close path
  // (every line fully received). Presence of this value also tells
  // applyComputedPoStatus to NOT revert a manual close if a downstream
  // receipt cancel later drops the received total — the operator's
  // explicit intent wins over the recomputed status.
  closeReason         String?
  cancelledAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  vendor    Vendor                       @relation(fields: [vendorId], references: [id])
  lines     PurchaseOrderLine[]
  billLinks BillPurchaseOrder[]
  shipments PoShipment[]
  payments  PoPayment[]
  tags      PurchaseOrderTagAssignment[]

  @@index([vendorId, status])
  @@index([status, expectedReceiveDate])
  @@index([deletedAt])
}

model PurchaseOrderLine {
  id                     String    @id @default(cuid())
  purchaseOrderId        String
  variantId              String
  warehouseId            String
  qtyOrdered             Decimal   @db.Decimal(18, 5)
  qtyReceived            Decimal   @default(0) @db.Decimal(18, 5)
  unitCost               Decimal   @db.Decimal(18, 5)
  vendorSku              String?
  manufacturerPartNumber String?
  notes                  String?
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  receiptLines  ReceiptLine[]

  @@index([purchaseOrderId])
  @@index([variantId])
  @@index([warehouseId])
}

model Receipt {
  id          String        @id @default(cuid())
  number      String        @unique
  vendorId    String
  warehouseId String
  status      ReceiptStatus @default(DRAFT)
  receivedAt  DateTime?
  postedById  String?
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor                Vendor                        @relation(fields: [vendorId], references: [id])
  warehouse             Warehouse                     @relation(fields: [warehouseId], references: [id])
  lines                 ReceiptLine[]
  // Back-relation: M:N to LandedCostAllocation via the join table.
  // Used by both the apply path (validate receipts → walk to layers)
  // and the reverse-lookup query "all landed-cost allocations applied
  // to this receipt" (vendor freight-bill reconciliation).
  landedCostAllocations LandedCostAllocationReceipt[]
  billLinks             BillReceipt[]

  @@index([vendorId, status])
  @@index([warehouseId, receivedAt])
  @@index([deletedAt])
}

// PO ↔ Receipt M:N is realized by: many ReceiptLines pointing at one POLine
// (a PO line can be received in multiple shipments) and a single Receipt
// having ReceiptLines pointing at POLines from different POs (one shipment
// covering multiple POs). No separate join table is needed.
model ReceiptLine {
  id                  String    @id @default(cuid())
  receiptId           String
  purchaseOrderLineId String?
  variantId           String
  warehouseId         String
  qtyReceived         Decimal   @db.Decimal(18, 5)
  unitCost            Decimal   @db.Decimal(18, 5)
  inventoryMovementId String?   @unique
  notes               String?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  receipt           Receipt            @relation(fields: [receiptId], references: [id])
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])
  variant           ProductVariant     @relation(fields: [variantId], references: [id])
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id])
  inventoryMovement InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])
  fifoLayer         FifoLayer?
  billLines         BillLine[]

  @@index([receiptId])
  @@index([purchaseOrderLineId])
  @@index([variantId, warehouseId])
}

model Customer {
  id                    String       @id @default(cuid())
  // Auto-issued CUST-YYYY-NNNNN via the Sequence helper. Original stub
  // exposed this as `code` and we keep that name for FK stability.
  code                  String       @unique
  // Display name. CITEXT makes the @unique case-insensitive natively.
  // Convention is to add `(City)` suffix on collision — see docs/03-customers.md.
  name                  String       @unique @db.Citext
  type                  CustomerType @default(WHOLESALE_REGULAR)
  // Required relations. Existing rows are backfilled to UNASSIGNED / NET30
  // before the NOT NULL flip in the migration.
  salesRepId            String
  paymentTermId         String
  // Financial terms.
  creditLimit           Decimal?     @db.Decimal(18, 5) // null = no limit
  arHoldDays            Int? // null = AR hold off
  taxExempt             Boolean      @default(false)
  resaleCertNumber      String?
  // Phone/email may be duplicated across customers (one owner, many stores).
  primaryPhone          String?
  primaryEmail          String?
  // Sticky internal notes — print on every internal document for this customer
  // (per docs/03-customers.md). Distinct from CustomerActivity (timeline) and
  // AuditLog (security/compliance ledger).
  internalNotes         String?
  shipstationCustomerId String? // ShipStation customer id — set when SS integration ships
  // Cost-plus % captured for future resolver branch; not wired in this slice.
  costPlusPercent       Decimal?     @db.Decimal(18, 5)
  active                Boolean      @default(true)
  deletedAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  salesRep            SalesRep                     @relation(fields: [salesRepId], references: [id])
  paymentTerm         PaymentTerm                  @relation(fields: [paymentTermId], references: [id])
  addresses           CustomerAddress[]
  contacts            CustomerContact[]
  priceOverrides      CustomerPriceOverride[]
  paymentMethods      CustomerPaymentMethod[]
  documents           CustomerDocument[]
  activities          CustomerActivity[]
  tags                CustomerTagAssignment[]
  categories          CustomerCategoryAssignment[]
  salesOrders         SalesOrder[]
  invoices            Invoice[]
  payments            Payment[]
  creditMemos         CreditMemo[]
  rmas                Rma[]
  pendingOrderReviews  PendingOrderReview[]         @relation("PendingOrderReviewMatchedCustomer")
  shopifyCustomerLinks ShopifyCustomerLink[]

  @@index([type])
  @@index([salesRepId])
  @@index([active, deletedAt])
  @@index([shipstationCustomerId])
  @@index([primaryEmail])
}

model SalesOrder {
  id                     String           @id @default(cuid())
  number                 String           @unique
  customerId             String
  warehouseId            String
  // Per-order sales-rep override. NULL = inherit the customer's rep
  // (customer.salesRepId) — the default. When set, THIS rep is the
  // order's effective rep: it drives commission accrual, "view own"
  // scoping, and display, without changing the customer's default. Set
  // via setSalesOrderSalesRep (Draft/Confirmed/Dispatched only).
  salesRepId             String?
  status                 SalesOrderStatus @default(DRAFT)
  source                 SalesOrderSource @default(STAFF)
  currency               String?          @default("USD")
  customerPo             String?
  promisedShipDate       DateTime?
  orderDate              DateTime         @default(now())
  // Order-level money. Decimal(18,5); rounding happens at display only.
  // discountPercent and discountAmount are mutually exclusive (Zod-enforced).
  orderDiscountPercent   Decimal?         @db.Decimal(18, 5)
  orderDiscountAmount    Decimal?         @db.Decimal(18, 5)
  shippingAmount         Decimal?         @db.Decimal(18, 5)
  handlingAmount         Decimal?         @db.Decimal(18, 5)
  // Free-text ship-to for pilot. The customer master slice will replace
  // this with a proper Address relation; intentionally nullable now.
  shippingAddress        String?
  customerNotes          String?
  internalNotes          String?
  createdById            String?
  // Lifecycle timestamps. Per docs/05-sales-orders.md, picked_at /
  // packed_at / shipping_calculated_at / invoice_generated_at /
  // payment_captured_at are flags-not-statuses and land with the
  // pick/pack/invoice workflows in later slices.
  confirmedAt            DateTime?
  dispatchedAt           DateTime?
  closedAt               DateTime?
  cancelledAt            DateTime?
  cancelReason           String?
  // Shopify provenance (set when source=SHOPIFY). shopifyOrderId is
  // unique to make the import path idempotent — a duplicate webhook fire
  // collides on the unique index and the importer short-circuits.
  // shopifyOrderNumber is the human "#1045" string Shopify shows in its
  // own admin; preserved for cross-referencing.
  shopifyOrderId         String?          @unique
  shopifyOrderNumber     String?
  shopifyStoreId         String?
  // External-payment flags. When true, payment was collected outside the
  // ERP (Shopify Payments, PayPal, etc.) — the SO close path still
  // generates an invoice but the payment is auto-recorded as method
  // EXTERNAL so AR stays balanced. For B2B Shopify imports, the operator
  // controls the AR flow and these flags stay false.
  isExternalPayment      Boolean          @default(false)
  externalPaymentStatus  String?
  externalPaymentGateway String?
  deletedAt              DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  customer     Customer                  @relation(fields: [customerId], references: [id])
  warehouse    Warehouse                 @relation(fields: [warehouseId], references: [id])
  salesRep     SalesRep?                 @relation(fields: [salesRepId], references: [id])
  lines        SalesOrderLine[]
  invoice      Invoice?
  tags         SalesOrderTagAssignment[]
  shopifyStore ShopifyStore?             @relation(fields: [shopifyStoreId], references: [id])

  @@index([customerId, status])
  @@index([status, orderDate])
  @@index([warehouseId])
  @@index([salesRepId])
  @@index([deletedAt])
  @@index([shopifyStoreId])
}

model SalesOrderLine {
  id                    String              @id @default(cuid())
  salesOrderId          String
  variantId             String
  warehouseId           String
  qtyOrdered            Decimal             @db.Decimal(18, 5)
  qtyReserved           Decimal             @default(0) @db.Decimal(18, 5)
  qtyShipped            Decimal             @default(0) @db.Decimal(18, 5)
  unitPrice             Decimal             @db.Decimal(18, 5)
  priceRule             PriceResolutionRule
  // discountPercent and discountAmount are mutually exclusive (Zod-enforced).
  discountPercent       Decimal?            @db.Decimal(18, 5)
  discountAmount        Decimal?            @db.Decimal(18, 5)
  customerNote          String?
  internalNote          String?
  // Set by closeSalesOrder once consumeInventoryTx creates the CONSUME
  // movement for this line. Part 3 of the costing engine slice walks
  // SOLine → InventoryMovement → FifoConsumption to compute COGS at
  // invoice time. Nullable for legacy / pre-close rows.
  inventoryMovementId   String?             @unique
  // Bundle grouping: when a BUNDLE product is added to an SO it
  // explodes into N component lines that all share the same
  // bundleGroupId + bundleSourceProductId. The bundle itself never
  // becomes a SalesOrderLine — components carry the data.
  // bundleSourceProductId points at the BUNDLE product so the UI can
  // render a synthetic header ("Bundle: NK-COMBO-3") above the group.
  bundleGroupId         String?
  bundleSourceProductId String?
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  salesOrder          SalesOrder         @relation(fields: [salesOrderId], references: [id])
  variant             ProductVariant     @relation(fields: [variantId], references: [id])
  warehouse           Warehouse          @relation(fields: [warehouseId], references: [id])
  inventoryMovement   InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])
  bundleSourceProduct Product?           @relation("BundleSourceSalesOrderLines", fields: [bundleSourceProductId], references: [id])

  @@index([salesOrderId])
  @@index([variantId, warehouseId])
  @@index([deletedAt])
  @@index([bundleGroupId])
}

// Admin-managed list. Seeded with Net 30, COD, Prepay, 50% deposit,
// Pay on shipping, Bill later (Net 30) by the migration; the seed file
// re-asserts these on every run.
model PaymentTerm {
  id        String    @id @default(cuid())
  code      String    @unique
  label     String
  netDays   Int? // null for COD/Prepay
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  customers            Customer[]
  vendors              Vendor[]
  shopifyStoreDefaults ShopifyStore[] @relation("ShopifyStoreDefaultPaymentTerm")
}

// Vendor address. Mirrors CustomerAddress but with VendorAddressKind
// (REMIT_TO is the AP destination). Singleton invariant "exactly one
// isDefault=true row per (vendorId, kind) among non-deleted rows" is
// enforced both by the service layer and by the partial unique index
// `vendoraddress_default_per_kind_idx`.
model VendorAddress {
  id         String            @id @default(cuid())
  vendorId   String
  kind       VendorAddressKind
  isDefault  Boolean           @default(false)
  label      String?
  line1      String
  line2      String?
  city       String
  region     String
  postalCode String
  country    String            @default("US")
  attention  String?
  phone      String?
  deletedAt  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId, kind])
  @@index([vendorId, isDefault])
}

// Vendor contact — multi per vendor with free-text role. Singleton
// invariant "exactly one isPrimary=true row per vendor among
// non-deleted rows" enforced by service + partial unique index
// `vendorcontact_primary_idx`.
model VendorContact {
  id        String    @id @default(cuid())
  vendorId  String
  name      String
  // Free-form per spec; common values: Sales rep, AR, AP, Buyer, Owner.
  role      String?
  email     String?
  phone     String?
  mobile    String?
  isPrimary Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

// Per-vendor per-variant catalog row. `latestCost` is "last known unit
// cost from this vendor" — distinct from FIFO layers (per-receipt) and
// WAC (computed). MOQ + lead time are deferred per docs/04 lines 30-31;
// nullable schema room only.
//
// Multi-vendor for one product: rare per spec. At most one isPrimary=true
// per variantId among non-deleted is enforced by partial unique index
// `vendorproduct_primary_idx`. Composite uniqueness on (vendorId,
// variantId) is enforced by partial unique index
// `vendorproduct_active_key` ignoring soft-deleted rows (so a soft-
// deleted catalog row can be re-created via the same upsert path).
// Same pattern as CustomerPriceOverride; @@unique declaration omitted
// because Prisma can't express partial indices.
model VendorProduct {
  id         String    @id @default(cuid())
  vendorId   String
  variantId  String
  vendorSku  String?
  latestCost Decimal?  @db.Decimal(18, 5)
  packSize   Decimal?  @db.Decimal(18, 5)
  isPrimary  Boolean   @default(false)
  active     Boolean   @default(true)
  notes      String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  vendor  Vendor         @relation(fields: [vendorId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([vendorId])
  @@index([variantId])
  @@index([deletedAt])
}

// Vendor payment-method record. The sensitive payload (account numbers,
// routing numbers, payee details, card metadata) is stored as a single
// AES-256-GCM ciphertext blob in `encryptedPayload` with the IV in
// `encryptedPayloadIv`. The blob is JSON-serialized and shape-validated
// by a kind-discriminated Zod schema after decrypt.
//
// `displayHint` (e.g. "ACH ****6789", "Check to: ACME LLC") is derived
// server-side from the cleartext payload at create time and stored in
// the clear so list/detail UIs don't have to decrypt to render a row.
//
// `isPreferred` invariant — at most one isPreferred=true per vendor
// among non-deleted rows — is enforced at the SERVICE layer only via
// row-locking the parent vendor and clearing other rows in the same
// transaction. No partial unique index (deliberate; mirrors
// CustomerDocument rather than CustomerPaymentMethod).
//
// SECURITY-CRITICAL: cleartext NEVER lands in the audit log or any
// other persisted store. The audited cleartext path writes a
// SENSITIVE_READ row with { vendorPaymentMethodId, kind } only, BEFORE
// attempting decryption.
model VendorPaymentMethod {
  id                 String                  @id @default(cuid())
  vendorId           String
  kind               VendorPaymentMethodKind
  // Optional human-readable label (e.g. "Operating account", "Backup ACH").
  label              String?
  // base64( ciphertext-bytes || 16-byte GCM auth tag )
  encryptedPayload   String
  // base64( 12-byte random IV )
  encryptedPayloadIv String
  // Server-derived non-sensitive summary for UI rows (e.g. "ACH ****6789").
  displayHint        String?
  isPreferred        Boolean                 @default(false)
  active             Boolean                 @default(true)
  deletedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

// Sales rep — minimal. The User ↔ SalesRep link is owned by User: a User
// optionally references a SalesRep via User.salesRepId (unique). The
// back-relation lives here as `user User?`. The orphan `userId String?`
// column that previously existed (slice 0 placeholder) is dropped in
// the auth-tables migration; all rows were NULL so the drop is safe.
// Commission rate fields are captured here for the commission slice;
// computation lives elsewhere.
model SalesRep {
  id                String           @id @default(cuid())
  code              String           @unique
  name              String
  email             String?
  active            Boolean          @default(true)
  // Per-rep gate. Salaried reps have this off so commission accruals
  // skip them entirely. Default false so newly-created reps don't
  // accidentally accrue.
  commissionEnabled Boolean          @default(false)
  commissionBasis   CommissionBasis?
  commissionPercent Decimal?         @db.Decimal(18, 5)
  // Group rate placeholder (future SalesRepGroup model).
  groupId           String?
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customers            Customer[]
  commissionAccruals   CommissionAccrual[]
  user                 User?
  // Sales orders whose rep was explicitly overridden to this rep
  // (SalesOrder.salesRepId). Orders that inherit the customer's rep do
  // NOT appear here.
  salesOrders          SalesOrder[]
  shopifyStoreDefaults ShopifyStore[]      @relation("ShopifyStoreDefaultSalesRep")
}

model CustomerAddress {
  id         String      @id @default(cuid())
  customerId String
  kind       AddressKind // BILLING or SHIPPING
  // Service layer enforces "exactly one isDefault=true per (customerId, kind)
  // among non-deleted rows" — also guarded by a partial unique index.
  isDefault  Boolean     @default(false)
  label      String? // e.g. "Warehouse", "Storefront"
  line1      String
  line2      String?
  city       String
  region     String // state/province
  postalCode String
  country    String      @default("US")
  // 'attention' is "what to write on the package" (name-only string), not a
  // FK to CustomerContact. Future cleanup: consider FK link in v2.
  attention  String?
  phone      String?
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, kind])
  @@index([customerId, isDefault])
}

model CustomerContact {
  id         String    @id @default(cuid())
  customerId String
  name       String
  // Free-form with autocomplete suggestions: Owner / Buyer / AP / AR / Manager / Shipping
  role       String?
  email      String?
  phone      String?
  mobile     String?
  // Service layer enforces "exactly one isPrimary=true per customer among
  // non-deleted rows" — also guarded by a partial unique index.
  isPrimary  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

// Per-customer per-variant price override. Wins over BASE_PRICE in the
// resolver; loses to MANUAL_OVERRIDE (caller-supplied). CSV import is
// UPSERT-ONLY: rows present in the CSV are inserted/updated; rows absent
// from the CSV are LEFT ALONE — never deleted via the import path.
//
// Uniqueness on (customerId, variantId) is enforced by a partial unique
// index `customerpriceoverride_active_key` that ignores soft-deleted
// rows — created in the price_override_partial_unique migration. Prisma
// can't express partial indices, so the @@unique declaration was
// removed; queries that previously used findUnique on the composite key
// now use findFirst with deletedAt:null in the filter.
model CustomerPriceOverride {
  id         String    @id @default(cuid())
  customerId String
  variantId  String
  unitPrice  Decimal   @db.Decimal(18, 5)
  currency   String?   @default("USD")
  notes      String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer       @relation(fields: [customerId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  // Lookups by (customerId, variantId) are served by the partial unique
  // index `customerpriceoverride_active_key` (declared in raw SQL in
  // the price_override_partial_unique migration). No separate
  // @@index([customerId, variantId]) needed.
  @@index([variantId])
  @@index([deletedAt])
}

// Authorize.Net CIM tokens only. NEVER store PAN, CVV, or anything
// PCI-relevant. Input validation rejects payloads that look like raw card
// numbers. See CLAUDE.md non-negotiable rules.
model CustomerPaymentMethod {
  id                            String    @id @default(cuid())
  customerId                    String
  authorizeNetCustomerProfileId String
  authorizeNetPaymentProfileId  String    @unique
  brand                         String?
  last4                         String?
  expirationMonth               Int?
  expirationYear                Int?
  // Service layer enforces "exactly one isPreferred=true per customer among
  // non-deleted rows" — also guarded by a partial unique index.
  isPreferred                   Boolean   @default(false)
  active                        Boolean   @default(true)
  deletedAt                     DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, isPreferred])
  @@index([expirationYear, expirationMonth])
}

// Document blobs live in DigitalOcean Spaces; this row stores metadata.
// EIN / SSN / DRIVERS_LICENSE values are stored as ciphertext via lib/crypto
// (AES-256-GCM); the cleartext read path emits a SENSITIVE_READ audit row.
model CustomerDocument {
  id               String               @id @default(cuid())
  customerId       String
  kind             CustomerDocumentKind
  // ciphertext (base64) + iv for kinds with a sensitive scalar value.
  encryptedValue   String?
  encryptedValueIv String?
  // For kinds with a file attachment.
  storageKey       String?
  fileName         String?
  contentType      String?
  expiresOn        DateTime?
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, kind])
  @@index([expiresOn])
}

// Customer-scoped business activity log. Distinct from AuditLog: AuditLog is
// the security/compliance ledger (who-did-what across the entire app);
// CustomerActivity is the customer-facing timeline a salesperson reads on
// the customer page. Sensitive customer changes (credit limit, AR hold,
// type, sales rep) write to BOTH — intentional, not redundant.
//
// detailJson conventions:
//   - AUTO entries: { field: string, from: any, to: any }
//   - MANUAL entries: null (the summary string is the whole content)
model CustomerActivity {
  id          String               @id @default(cuid())
  customerId  String
  kind        CustomerActivityKind
  summary     String
  detailJson  Json?
  createdById String?
  createdAt   DateTime             @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
}

// Pre-made list, admin-managed. The `code` column is the stable identifier
// admins reference in scripts/imports (CustomerTag is label-only by design
// — tags are sales-rep ad-hoc, categories are operations-managed lists).
model CustomerCategory {
  id        String    @id @default(cuid())
  code      String    @unique
  label     String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignments CustomerCategoryAssignment[]
}

model CustomerCategoryAssignment {
  customerId String
  categoryId String
  createdAt  DateTime @default(now())

  customer Customer         @relation(fields: [customerId], references: [id])
  category CustomerCategory @relation(fields: [categoryId], references: [id])

  @@id([customerId, categoryId])
  @@index([categoryId])
}

// Free-form, autocomplete-driven. Tag rows are created lazily on first use.
model CustomerTag {
  id        String   @id @default(cuid())
  label     String   @unique @db.Citext
  createdAt DateTime @default(now())

  assignments CustomerTagAssignment[]
}

model CustomerTagAssignment {
  customerId String
  tagId      String
  createdAt  DateTime @default(now())

  customer Customer    @relation(fields: [customerId], references: [id])
  tag      CustomerTag @relation(fields: [tagId], references: [id])

  @@id([customerId, tagId])
  @@index([tagId])
}

// Global product tags — shared across all products, created lazily on
// first use via the autocomplete editor. Name is CITEXT so "Organic"
// and "organic" collide in the unique index.
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique @db.Citext
  createdAt DateTime @default(now())

  products ProductTag[]
}

model ProductTag {
  id        String   @id @default(cuid())
  productId String
  tagId     String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@unique([productId, tagId])
  @@index([tagId])
}

// Shared "operational workflow" tag dictionary — created lazily on first
// use via the autocomplete editor. Reused across the operational entities
// (SalesOrder, PurchaseOrder, Bill, CreditMemo, Rma, WorkOrder,
// VendorCredit) so a tag like "URGENT" or "Q3" applies to any record and
// the autocomplete pool stays consistent. Each entity has its own
// assignment table that FKs into this dictionary. Distinct from Product
// `Tag` (product attributes) and `CustomerTag` (customer categorization),
// which keep their own dictionaries.
model OrderTag {
  id        String   @id @default(cuid())
  name      String   @unique @db.Citext
  createdAt DateTime @default(now())

  salesOrderAssignments    SalesOrderTagAssignment[]
  purchaseOrderAssignments PurchaseOrderTagAssignment[]
  billAssignments          BillTagAssignment[]
  creditMemoAssignments    CreditMemoTagAssignment[]
  rmaAssignments           RmaTagAssignment[]
  workOrderAssignments     WorkOrderTagAssignment[]
  vendorCreditAssignments  VendorCreditTagAssignment[]
}

model SalesOrderTagAssignment {
  salesOrderId String
  tagId        String
  createdAt    DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  tag        OrderTag   @relation(fields: [tagId], references: [id])

  @@id([salesOrderId, tagId])
  @@index([tagId])
}

model PurchaseOrderTagAssignment {
  purchaseOrderId String
  tagId           String
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  tag           OrderTag      @relation(fields: [tagId], references: [id])

  @@id([purchaseOrderId, tagId])
  @@index([tagId])
}

model BillTagAssignment {
  billId    String
  tagId     String
  createdAt DateTime @default(now())

  bill Bill     @relation(fields: [billId], references: [id])
  tag  OrderTag @relation(fields: [tagId], references: [id])

  @@id([billId, tagId])
  @@index([tagId])
}

model CreditMemoTagAssignment {
  creditMemoId String
  tagId        String
  createdAt    DateTime @default(now())

  creditMemo CreditMemo @relation(fields: [creditMemoId], references: [id])
  tag        OrderTag   @relation(fields: [tagId], references: [id])

  @@id([creditMemoId, tagId])
  @@index([tagId])
}

model RmaTagAssignment {
  rmaId     String
  tagId     String
  createdAt DateTime @default(now())

  rma Rma      @relation(fields: [rmaId], references: [id])
  tag OrderTag @relation(fields: [tagId], references: [id])

  @@id([rmaId, tagId])
  @@index([tagId])
}

model WorkOrderTagAssignment {
  workOrderId String
  tagId       String
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  tag       OrderTag  @relation(fields: [tagId], references: [id])

  @@id([workOrderId, tagId])
  @@index([tagId])
}

model VendorCreditTagAssignment {
  vendorCreditId String
  tagId          String
  createdAt      DateTime @default(now())

  vendorCredit VendorCredit @relation(fields: [vendorCreditId], references: [id])
  tag          OrderTag     @relation(fields: [tagId], references: [id])

  @@id([vendorCreditId, tagId])
  @@index([tagId])
}

// Inventory adjustment header. Quick adjustments post immediately
// (status POSTED); the batch flow (future slice) uses DRAFT → POSTED.
// VOIDED adjustments are reversed via a compensating set of opposite
// movements + a reversing JE (originals are never mutated).
model InventoryAdjustment {
  id             String             @id @default(cuid())
  number         String             @unique // ADJ-YYYY-NNNNN via Sequence
  warehouseId    String
  adjustmentDate DateTime           @default(now())
  category       AdjustmentCategory
  reason         String
  internalNotes  String?
  status         AdjustmentStatus   @default(DRAFT)
  postedAt       DateTime?
  voidedAt       DateTime?
  voidReason     String?
  createdById    String?
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  warehouse Warehouse                 @relation(fields: [warehouseId], references: [id])
  lines     InventoryAdjustmentLine[]

  @@index([warehouseId, status])
  @@index([status, adjustmentDate])
  @@index([deletedAt])
}

model InventoryAdjustmentLine {
  id           String   @id @default(cuid())
  adjustmentId String
  variantId    String
  // Signed: positive adds stock (gain), negative removes (loss).
  qtyChange    Decimal  @db.Decimal(18, 5)
  // Gain: cost the new FIFO layer was created at (WAC/last cost).
  // Loss: FIFO-consumed cost (system-calculated). 0 when no value flowed.
  unitCost     Decimal  @default(0) @db.Decimal(18, 5)
  notes        String?
  createdAt    DateTime @default(now())

  adjustment InventoryAdjustment @relation(fields: [adjustmentId], references: [id])
  variant    ProductVariant      @relation(fields: [variantId], references: [id])

  @@index([adjustmentId])
  @@index([variantId])
}

// Generic admin-managed key/value settings table. Replaces the
// single-row pattern (RestockingFeeDefault, etc.) — every future
// admin setting (late-fee %, AR-hold default, negative-inventory
// flag, ...) lives here as a typed JSON value validated by a per-key
// Zod schema in the service layer. updatedBy is nullable until
// auth/RBAC ships.
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Per-user UI preferences (e.g. list-page column visibility + image
// default). Mirrors Setting's key/value-JSON shape but scoped per user.
// userId is a loose reference (no FK) — same convention as AuditLog — so a
// preference row is independent of the auth-owned User lifecycle. Each
// (userId, key) holds one JSON blob; the shape is validated per-key in the
// service layer. Reusable across list pages via distinct keys
// ("table.products", "table.vendors", …).
model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

// Invoice generated automatically when a SalesOrder closes.
//
// Numbering: Invoice.number = SalesOrder.number per docs/06-invoicing-ar.md
// (no separate Sequence allocator in pilot). Drop-ship splits where
// child invoices become `{SO}-1` are deferred — when that lands, the
// unique constraint on `salesOrderId` relaxes to a per-SO sequence.
//
// cogsPosted is false until the costing engine slice retroactively
// posts the COGS leg of the SO-close JE. Until then, P&L reports
// overstate net income by the COGS amount of all closed SOs (see
// CLAUDE.md operational notes).
model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  // Nullable + @unique = partial-unique on non-null (Postgres treats
  // multiple NULLs as distinct). On reopen we NULL the FK to detach
  // the invoice from the SO without voiding it; the orphan record
  // stays queryable by id, applications + JE rows untouched. A
  // subsequent close generates a fresh invoice cleanly because the
  // unique index ignores the NULL'd row.
  salesOrderId   String?       @unique
  customerId     String
  warehouseId    String
  status         InvoiceStatus @default(OPEN)
  // Money snapshot at generation. Immutable except via CreditMemo.
  subtotal       Decimal       @db.Decimal(18, 5)
  orderDiscount  Decimal       @default(0) @db.Decimal(18, 5)
  shippingAmount Decimal       @default(0) @db.Decimal(18, 5)
  handlingAmount Decimal       @default(0) @db.Decimal(18, 5)
  total          Decimal       @db.Decimal(18, 5)
  // Denormalized counters; recompute helpers in the service.
  amountPaid     Decimal       @default(0) @db.Decimal(18, 5)
  amountCredited Decimal       @default(0) @db.Decimal(18, 5)
  currency       String?       @default("USD")
  invoiceDate    DateTime      @default(now())
  customerNotes  String?
  internalNotes  String?
  storedPdfKey   String? // populated on first email; PDF slice deferred
  emailedAt      DateTime?
  voidedAt       DateTime?
  voidReason     String?
  // Flipped to true by the costing engine slice when COGS is retro-posted.
  cogsPosted     Boolean       @default(false)
  // Total COGS computed at posting time (sum across all bins). Stored
  // for fast MARGIN-basis commission accrual lookups; zero-COGS
  // invoices (drop-ship/service-only) write 0. NULL on pre-migration
  // closed invoices — accrual treats NULL as 0 for MARGIN math.
  cogsAtClose    Decimal?      @db.Decimal(18, 5)
  // Flipped to true by reverseCogsForInvoiceTx (Part 3.5) when voidInvoice
  // reverses the COGS leg. Idempotency anchor: re-call after reversal
  // sees this and short-circuits.
  cogsReversed   Boolean       @default(false)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  salesOrder         SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  customer           Customer            @relation(fields: [customerId], references: [id])
  warehouse          Warehouse           @relation(fields: [warehouseId], references: [id])
  lines              InvoiceLine[]
  applications       CreditApplication[]
  creditMemos        CreditMemo[]
  rmas               Rma[]
  commissionAccruals CommissionAccrual[]

  @@index([customerId, status])
  @@index([status, invoiceDate])
  @@index([cogsPosted])
  @@index([deletedAt])
}

// Snapshot of SO line at close-time. Decoupled from SOLine so SO edits
// after close can never mutate posted invoices.
model InvoiceLine {
  id                    String    @id @default(cuid())
  invoiceId             String
  salesOrderLineId      String?
  variantId             String
  description           String
  qty                   Decimal   @db.Decimal(18, 5)
  unitPrice             Decimal   @db.Decimal(18, 5)
  discountPercent       Decimal?  @db.Decimal(18, 5)
  discountAmount        Decimal?  @db.Decimal(18, 5)
  lineTotal             Decimal   @db.Decimal(18, 5)
  qtyReturned           Decimal   @default(0) @db.Decimal(18, 5)
  // Bundle grouping, copied from SalesOrderLine at invoice generation
  // time. The PDF template doesn't render bundle headers yet (deferred
  // slice) but the data is preserved so it can.
  bundleGroupId         String?
  bundleSourceProductId String?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  invoice             Invoice          @relation(fields: [invoiceId], references: [id])
  variant             ProductVariant   @relation(fields: [variantId], references: [id])
  rmaLines            RmaLine[]
  creditMemoLines     CreditMemoLine[]
  bundleSourceProduct Product?         @relation("BundleSourceInvoiceLines", fields: [bundleSourceProductId], references: [id])

  @@index([invoiceId])
  @@index([variantId])
  @@index([bundleGroupId])
}

// A money-receiving event. One Payment can be split across many
// invoices (or none — unapplied) via CreditApplication rows.
model Payment {
  id             String        @id @default(cuid())
  number         String        @unique // PMT-YYYY-NNNNN via Sequence
  customerId     String
  method         PaymentMethod
  status         PaymentStatus @default(RECORDED)
  amount         Decimal       @db.Decimal(18, 5)
  appliedAmount  Decimal       @default(0) @db.Decimal(18, 5)
  currency       String?       @default("USD")
  receivedAt     DateTime      @default(now())
  reference      String?
  notes          String?
  // Deposit account for the cash-receipt JE (DR cashAccount / CR AR).
  // Operator-picked per payment (cash/bank ASSET, or a credit-card
  // LIABILITY). Nullable: APPLIED_CREDIT payments post no cash JE, and
  // legacy rows predate the field (the service falls back to 1110).
  cashAccountId  String?
  reversedAt     DateTime?
  reversedReason String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer            Customer            @relation(fields: [customerId], references: [id])
  cashAccount         GlAccount?          @relation(fields: [cashAccountId], references: [id])
  applications        CreditApplication[]
  commissionAccruals  CommissionAccrual[] @relation("CommissionPaymentSource")
  reversedCommissions CommissionAccrual[] @relation("CommissionReversedBy")

  @@index([customerId, receivedAt])
  @@index([status, receivedAt])
}

// Commission ledger. One row per (payment-application × salesRep)
// when a payment posts; reversal writes a negative-amount mirror row
// that points back to the original via reversedByPaymentId. Original
// rows are NEVER mutated except for reversedAt — the audit trail is
// the sequence of rows.
//
// basis + percent are snapshotted from the SalesRep at accrual time
// so subsequent rep edits don't rewrite history. amount =
// basisAmount * percent / 100 (REVENUE) or = (basisAmount - propCogs)
// * percent / 100 (MARGIN); always Decimal precision, never JS Number.
model CommissionAccrual {
  id                  String          @id @default(cuid())
  salesRepId          String
  paymentId           String
  invoiceId           String
  basis               CommissionBasis
  basisAmount         Decimal         @db.Decimal(18, 5) // applied amount on REVENUE; (applied − propCOGS) on MARGIN — what the percent multiplied
  percent             Decimal         @db.Decimal(18, 5)
  amount              Decimal         @db.Decimal(18, 5) // signed: positive on accrual, negative on reversal
  accruedAt           DateTime
  // When set, this row was reversed by a later reversal row. Original
  // row stays untouched in the ledger; the back-reference is via
  // reversedByPaymentId on the negative mirror row.
  reversedAt          DateTime?
  // On a negative reversal row: the Payment whose reversal triggered
  // the mirror. Same as paymentId for self-payment reversals; differs
  // for future RMA-triggered reversals.
  reversedByPaymentId String?
  createdAt           DateTime        @default(now())

  salesRep          SalesRep @relation(fields: [salesRepId], references: [id])
  payment           Payment  @relation("CommissionPaymentSource", fields: [paymentId], references: [id])
  invoice           Invoice  @relation(fields: [invoiceId], references: [id])
  reversedByPayment Payment? @relation("CommissionReversedBy", fields: [reversedByPaymentId], references: [id])

  @@index([salesRepId, accruedAt])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([reversedByPaymentId])
}

// Admin-managed list of credit-memo categories. Self-serve in admin
// per spec. affectsInventory tells the credit-memo confirmation path
// whether to emit a structured restock event for the future costing
// engine slice.
model CreditMemoCategory {
  id               String    @id @default(cuid())
  code             String    @unique
  label            String
  affectsInventory Boolean   @default(true)
  // Optional FK to GlAccount. When set, reverseCogsForCreditMemoTx posts
  // DR <lossAccount> / CR COGS instead of restoring inventory — the
  // loss-reclassification path. Admin-managed: shipping-damage,
  // manufacturer-defect, and miscellaneous-damage categories route here.
  // RETURN, GOODWILL, PRICING_DISPUTE, CANCELLED leave this NULL.
  lossAccountId    String?
  active           Boolean   @default(true)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  memos       CreditMemo[]
  lossAccount GlAccount?   @relation(fields: [lossAccountId], references: [id])

  @@index([lossAccountId])
}

model CreditMemo {
  id            String           @id @default(cuid())
  number        String           @unique // CM-YYYY-NNNNN via Sequence
  customerId    String
  invoiceId     String?
  status        CreditMemoStatus @default(DRAFT)
  categoryId    String
  amount        Decimal          @db.Decimal(18, 5)
  restockingFee Decimal          @default(0) @db.Decimal(18, 5)
  netCredit     Decimal          @db.Decimal(18, 5)
  appliedAmount Decimal          @default(0) @db.Decimal(18, 5)
  currency      String?          @default("USD")
  reason        String?
  issuedAt      DateTime?
  voidedAt      DateTime?
  voidReason    String?
  // Flipped to true by reverseCogsForCreditMemoTx (Part 3.5) when an
  // RMA-driven CM has its COGS reversed. Per-CM idempotency: independent
  // of Invoice.cogsReversed because multiple CMs can target a single
  // invoice (partial returns).
  cogsReversed  Boolean          @default(false)
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  customer     Customer                  @relation(fields: [customerId], references: [id])
  invoice      Invoice?                  @relation(fields: [invoiceId], references: [id])
  category     CreditMemoCategory        @relation(fields: [categoryId], references: [id])
  rma          Rma?
  lines        CreditMemoLine[]
  applications CreditApplication[]
  tags         CreditMemoTagAssignment[]

  @@index([customerId, status])
  @@index([invoiceId])
}

model CreditMemoLine {
  id            String    @id @default(cuid())
  creditMemoId  String
  invoiceLineId String?
  variantId     String
  qty           Decimal   @db.Decimal(18, 5)
  unitPrice     Decimal   @db.Decimal(18, 5)
  lineTotal     Decimal   @db.Decimal(18, 5)
  description   String
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creditMemo  CreditMemo     @relation(fields: [creditMemoId], references: [id])
  invoiceLine InvoiceLine?   @relation(fields: [invoiceLineId], references: [id])
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([creditMemoId])
}

model Rma {
  id                   String    @id @default(cuid())
  number               String    @unique // RMA-YYYY-NNNNN
  customerId           String
  invoiceId            String
  status               RmaStatus @default(PENDING)
  returnless           Boolean   @default(false)
  reason               String?
  // Restocking-fee policy at RMA creation. Defaults sourced from
  // Setting('restocking_fee_default'); both nullable so an RMA can
  // explicitly carry "no restocking fee" overrides.
  restockingFeePercent Decimal?  @db.Decimal(18, 5)
  restockingFeeFlat    Decimal?  @db.Decimal(18, 5)
  approvedAt           DateTime?
  receivedAt           DateTime?
  inspectedAt          DateTime?
  creditedAt           DateTime?
  rejectedAt           DateTime?
  rejectedReason       String?
  creditMemoId         String?   @unique
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customer   Customer           @relation(fields: [customerId], references: [id])
  invoice    Invoice            @relation(fields: [invoiceId], references: [id])
  creditMemo CreditMemo?        @relation(fields: [creditMemoId], references: [id])
  lines      RmaLine[]
  tags       RmaTagAssignment[]

  @@index([customerId, status])
  @@index([status])
}

model RmaLine {
  id            String    @id @default(cuid())
  rmaId         String
  invoiceLineId String
  qty           Decimal   @db.Decimal(18, 5)
  reason        String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rma         Rma         @relation(fields: [rmaId], references: [id])
  invoiceLine InvoiceLine @relation(fields: [invoiceLineId], references: [id])

  @@index([rmaId])
}

// Single source of truth for "this dollar of payment/credit was
// applied to that dollar of invoice." Reversed apps are kept
// (reversedAt set) so the audit trail survives.
//
// Two partial unique indices on (paymentId, invoiceId) and
// (creditMemoId, invoiceId) — both filtered by reversedAt IS NULL —
// prevent multi-applying the same payment or credit memo to the same
// invoice while live. Created in raw SQL in the migration since
// Prisma can't express partial indices.
model CreditApplication {
  id           String                @id @default(cuid())
  kind         CreditApplicationKind
  paymentId    String?
  creditMemoId String?
  invoiceId    String
  amount       Decimal               @db.Decimal(18, 5)
  appliedAt    DateTime              @default(now())
  appliedById  String?
  reversedAt   DateTime?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  payment    Payment?    @relation(fields: [paymentId], references: [id])
  creditMemo CreditMemo? @relation(fields: [creditMemoId], references: [id])
  invoice    Invoice     @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId, reversedAt])
  @@index([paymentId])
  @@index([creditMemoId])
}

// =========================================================================
// GL stub — minimum needed for the Invoicing & AR slice's auto-JE posts.
//
// Full Chart of Accounts module (hierarchy / parent accounts / period
// close / multi-warehouse inventory accounts / manual JEs / admin
// reversal with closed-period gating) ships in its own slice (Module 7,
// docs/08-gl-costing-reporting.md). This stub is the minimum set of
// shapes the AR auto-posts need to land — same pattern as the Vendor /
// Customer / SalesRep stubs that came before their full slices.
// =========================================================================

model GlAccount {
  id        String      @id @default(cuid())
  // Numeric account code per the spec (1000–9999). Stable identifier
  // for service-layer references (e.g., findByCode('1210')).
  code      String      @unique
  name      String
  type      AccountType
  // Hierarchy / parent-account / sub-account fields land with the GL
  // slice. Stub keeps a flat list.
  active    Boolean     @default(true)
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  journalEntryLines    JournalEntryLine[]
  warehouses           Warehouse[]
  creditMemoCategories CreditMemoCategory[]
  billLines            BillLine[]
  billPayments         BillPayment[]
  payments             Payment[]
  poPayments           PoPayment[]

  @@index([type])
}

model JournalEntry {
  id          String    @id @default(cuid())
  number      String    @unique // JE-YYYY-NNNNN via Sequence
  // Operational source — cross-references the entity that triggered
  // the post. Used by the GL slice for drill-down and by the AR
  // slice's reversal paths to find the JE to reverse.
  entityType  String
  entityId    String
  postedAt    DateTime  @default(now())
  description String
  // Optional JE-level metadata. Populated by Account Transfers (manual
  // money movement between GL accounts): reference = check/confirmation #,
  // notes = free-text memo. Null for system-posted operational JEs.
  reference   String?
  notes       String?
  // Set when the operational entity is voided / payment-reversed /
  // CM-voided. The full GL slice will add admin manual-reverse
  // capability with proper period-close gating.
  reversedAt  DateTime?
  reversedBy  String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines                     JournalEntryLine[]
  // Back-relation: rows in LandedCostAllocationLine that point to this
  // JE as the per-layer COGS adjustment anchor. Forward COGS adjustment
  // JEs and reversal JEs both flow through here; query by
  // (entityType='Invoice', description LIKE 'Late landed cost%') to
  // separate from regular COGS.
  landedCostAllocationLines LandedCostAllocationLine[]
  // Back-relation: Work Order completion events that posted this JE.
  workOrderCompletions      WorkOrderCompletion[]
  // Back-relation: PoPayment rows whose deposit JE is recorded here.
  poPayments                PoPayment[]

  @@index([entityType, entityId])
  @@index([postedAt])
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  // Conventional double-entry: debit and credit are mutually exclusive,
  // both >= 0. The post() helper enforces SUM(debits) = SUM(credits)
  // before insertion.
  debit          Decimal  @default(0) @db.Decimal(18, 5)
  credit         Decimal  @default(0) @db.Decimal(18, 5)
  memo           String?
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      GlAccount    @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// =========================================================================
// Part 4 of the costing engine slice: late landed cost retroactive
// adjustment. Apply path mutates affected FifoLayer.unitCost values and
// posts COGS adjustment JEs (backdated via post() postedAt parameter)
// for already-realized sales. Reverse path restores from
// LandedCostAllocationLine.originalUnitCost snapshots and posts mirror-
// sign reversal JEs. See src/server/services/landedCost.ts.
//
// sourceBillId is a plain TEXT? for now — the Bill model lives in the
// future Bills/AP slice (phase 8). When that slice lands, an additive
// migration adds the FK constraint. Until then sourceBillId can hold
// the vendor's invoice number string for operator reference.
// =========================================================================

model LandedCostAllocation {
  id               String           @id @default(cuid())
  totalLandedCost  Decimal          @db.Decimal(18, 5)
  allocationMethod AllocationMethod
  appliedAt        DateTime         @default(now())
  // Audit-only; no FK to a User table because users live in BetterAuth's
  // auth schema, not the tenant schema. Mirrors the existing pattern on
  // Receipt.postedById, JournalEntry.reversedBy, CreditApplication.appliedById.
  appliedById      String?
  reversedAt       DateTime?
  reversedReason   String?
  // Reference to the vendor bill that funded this allocation. No FK
  // until the future Bills/AP slice creates the Bill model. Operators
  // can store vendor invoice numbers here in the meantime.
  sourceBillId     String?
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  lines    LandedCostAllocationLine[]
  receipts LandedCostAllocationReceipt[]

  @@index([appliedAt])
  @@index([reversedAt])
  @@index([sourceBillId])
  @@index([deletedAt])
}

// Per-FifoLayer impact row. originalUnitCost is the snapshot taken
// BEFORE allocation, used by reverseLandedCostAllocation to restore
// the layer cost (NOT layer.unitCost - deltaUnitCost — the snapshot is
// the source of truth, immune to any subsequent allocation that may
// have stacked on top before reversal).
//
// cogsAdjustmentJeId is nullable / first-of-N. Three cases:
//   1. NULL because the layer had no FifoConsumption rows at allocation
//      time (no sales yet — nothing to adjust).
//   2. NULL because every consumption on the layer tied to a not-yet-
//      cogs-posted invoice (forward path mutated FifoConsumption.unitCost
//      in place; no separate JE — see FifoConsumption.unitCost comment).
//   3. SET to the FIRST cogs-adjustment JE for this (allocation, layer)
//      tuple, sorted by (invoiceNumber asc, warehouseId asc), when the
//      layer's consumptions feed one or more (invoice, warehouse) pairs
//      whose invoice is cogsPosted=true. Sibling JEs (when consumptions
//      span multiple (invoice, warehouse) pairs) are NOT recorded on a
//      separate row in pilot scope; they're findable via the JE
//      description query:
//        description LIKE 'Late landed cost adjustment%allocation <id>'
//      using the JournalEntry_postedAt_idx + (entityType, entityId)
//      index. The "first-of-N" convention is documented here so future
//      readers don't assume 1:1.
model LandedCostAllocationLine {
  id                 String   @id @default(cuid())
  allocationId       String
  fifoLayerId        String
  deltaUnitCost      Decimal  @db.Decimal(18, 5)
  deltaTotal         Decimal  @db.Decimal(18, 5)
  originalUnitCost   Decimal  @db.Decimal(18, 5)
  cogsAdjustmentJeId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  allocation       LandedCostAllocation @relation(fields: [allocationId], references: [id])
  fifoLayer        FifoLayer            @relation(fields: [fifoLayerId], references: [id])
  cogsAdjustmentJe JournalEntry?        @relation(fields: [cogsAdjustmentJeId], references: [id])

  @@index([allocationId])
  @@index([fifoLayerId])
  @@index([cogsAdjustmentJeId])
}

// M:N join between LandedCostAllocation and Receipt. No deletedAt — the
// parent's reversedAt + deletedAt is sufficient for state tracking;
// join rows are pure association.
model LandedCostAllocationReceipt {
  id           String   @id @default(cuid())
  allocationId String
  receiptId    String
  createdAt    DateTime @default(now())

  allocation LandedCostAllocation @relation(fields: [allocationId], references: [id])
  receipt    Receipt              @relation(fields: [receiptId], references: [id])

  @@unique([allocationId, receiptId])
  @@index([receiptId])
}

// =========================================================================
// Bills / AP — phase 8 slice. Vendor invoices, bill payments, vendor
// credits. Spec: docs/07-accounts-payable.md.
//
// Architecture: PO ↔ Receipt ↔ Bill is many-to-many. Realized via
// BillReceipt + BillPurchaseOrder join tables — one bill can cover lines
// from multiple receipts and POs (one vendor invoice, three POs, one
// receipt is a real case). Mirrors the PO↔Receipt M:N convention which
// is realized via ReceiptLine.purchaseOrderLineId rather than a dedicated
// join table; here we use explicit join rows because the linkage is at
// the header level, not the line level.
//
// Auto-JE postings (via lib/gl/post.ts):
//   Bill confirmed (PRODUCT) → DR 2020 Accrued Receipts / CR 2010 AP
//   Bill confirmed (EXPENSE) → DR <expenseAccount> / CR 2010 AP
//   Bill payment recorded   → DR 2010 AP / CR <cashAccount>
//   VC confirmed            → DR 2010 AP / CR 2030 Vendor Credits Avail
//   VC applied to bill      → DR 2030 Vendor Credits Avail / CR 2010 AP
// =========================================================================

model Bill {
  id              String            @id @default(cuid())
  number          String            @unique // BILL-YYYY-NNNNN via Sequence
  vendorId        String
  // Vendor's own invoice number — operator-entered reference for
  // reconciliation. Not unique (vendor numbering can recycle across
  // years; we don't police it).
  vendorReference String?
  source          BillSource        @default(PRODUCT)
  status          BillStatus        @default(DRAFT)
  paymentStatus   BillPaymentStatus @default(UNPAID)
  billDate        DateTime          @default(now())
  // Computed at confirm time from vendor.paymentTerm.netDays. Null on
  // DRAFT (and on CONFIRMED if the vendor's payment term is COD/Prepay
  // — matches AR semantics: netDays === null → due immediately).
  dueDate         DateTime?
  // Money snapshot. Immutable after CONFIRMED except via cancel.
  // Decimal(18,5) per the project-wide money rule.
  subtotal        Decimal           @db.Decimal(18, 5)
  freight         Decimal           @default(0) @db.Decimal(18, 5)
  tax             Decimal           @default(0) @db.Decimal(18, 5)
  total           Decimal           @db.Decimal(18, 5)
  // Denormalized counters; recompute helpers in the service.
  // amountCredited = SUM of non-reversed VendorCreditApplication.amount
  // pointing at this bill. paymentStatus is derived: total > 0 and
  // (amountPaid + amountCredited) >= total → PAID; > 0 → PARTIAL.
  amountPaid      Decimal           @default(0) @db.Decimal(18, 5)
  amountCredited  Decimal           @default(0) @db.Decimal(18, 5)
  // SUM of non-reversed PoPaymentApplication.amount pointing at this bill.
  // PO deposits relieve AP just like a payment; folded into the settled
  // total alongside amountPaid + amountCredited when deriving paymentStatus.
  amountDeposited Decimal           @default(0) @db.Decimal(18, 5)
  currency        String?           @default("USD")
  notes           String?
  createdById     String?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  vendor                Vendor                    @relation(fields: [vendorId], references: [id])
  lines                 BillLine[]
  payments              BillPayment[]
  creditApplications    VendorCreditApplication[]
  receipts              BillReceipt[]
  purchaseOrders        BillPurchaseOrder[]
  poPaymentApplications PoPaymentApplication[]
  tags                  BillTagAssignment[]

  @@index([vendorId, status])
  @@index([status, billDate])
  @@index([paymentStatus])
  @@index([deletedAt])
}

// M:N join. Composite PK enforces (billId, receiptId) uniqueness; no
// soft-delete on join rows — cancel the parent Bill instead.
//
// onDelete: Cascade on both sides — the join row is pure association
// and meaningless without either parent. Production never hard-deletes
// either Bill or Receipt (soft-delete only), so cascade fires only in
// test cleanup; data integrity is unchanged in production.
model BillReceipt {
  billId    String
  receiptId String
  createdAt DateTime @default(now())

  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@id([billId, receiptId])
  @@index([receiptId])
}

model BillPurchaseOrder {
  billId          String
  purchaseOrderId String
  createdAt       DateTime @default(now())

  bill          Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@id([billId, purchaseOrderId])
  @@index([purchaseOrderId])
}

// Discriminator: when bill.source = PRODUCT, variantId is required and
// expenseAccountId is null. When bill.source = EXPENSE, expenseAccountId
// is required and variantId is null. Service-layer validates;
// schema-level enforcement of the XOR is via raw SQL CHECK constraint
// in the migration.
model BillLine {
  id               String    @id @default(cuid())
  billId           String
  lineNumber       Int
  // PRODUCT path:
  variantId        String?
  // Optional traceability to specific receipt line (when this bill
  // line was matched against a receipt during bill entry). Helps
  // reconcile receipt-vs-bill cost variances downstream. Null on
  // bills entered without a receipt match.
  receiptLineId    String?
  // EXPENSE path:
  expenseAccountId String? // FK to GlAccount; service validates type=EXPENSE
  description      String
  qty              Decimal   @db.Decimal(18, 5)
  unitCost         Decimal   @db.Decimal(18, 5)
  lineTotal        Decimal   @db.Decimal(18, 5)
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // variantId + expenseAccountId use ON DELETE RESTRICT (NOT the
  // Prisma default of SET NULL for nullable FKs). Reason: BillLine_source_xor
  // CHECK constraint requires exactly one of the two to be non-null —
  // if a SET NULL fires from the discriminator column it sets, the
  // remaining discriminator stays null and the row violates the CHECK.
  // RESTRICT forces test cleanup (production never hard-deletes
  // variants or GL accounts) to delete bills first.
  // receiptLineId stays SET NULL — losing the receipt traceability
  // doesn't violate XOR because variantId stays set on the PRODUCT line.
  bill           Bill            @relation(fields: [billId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
  receiptLine    ReceiptLine?    @relation(fields: [receiptLineId], references: [id])
  expenseAccount GlAccount?      @relation(fields: [expenseAccountId], references: [id], onDelete: Restrict)

  @@index([billId])
  @@index([variantId])
  @@index([receiptLineId])
  @@index([expenseAccountId])
}

// A money-leaving event on the AP side. Mirrors Payment on AR.
// Reuses PaymentMethod and PaymentStatus enums — same money-movement
// semantics, different table. APPLIED_CREDIT method is NOT used here:
// vendor credits flow via VendorCreditApplication with their own JE
// (DR 2030 / CR 2010), not as a BillPayment row.
model BillPayment {
  id             String        @id @default(cuid())
  number         String        @unique // BPMT-YYYY-NNNNN via Sequence
  billId         String
  // Denorm for vendor-payment-history queries without a Bill join.
  vendorId       String
  paymentDate    DateTime      @default(now())
  amount         Decimal       @db.Decimal(18, 5)
  method         PaymentMethod
  // Bank/cash account credited. FK to GlAccount; service validates
  // type = ASSET (typically 1110 Cash/Bank).
  cashAccountId  String?
  reference      String? // check #, wire ref, ACH trace, etc.
  notes          String?
  status         PaymentStatus @default(RECORDED)
  reversedAt     DateTime?
  reversedReason String?
  createdById    String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  bill        Bill       @relation(fields: [billId], references: [id])
  vendor      Vendor     @relation(fields: [vendorId], references: [id])
  cashAccount GlAccount? @relation(fields: [cashAccountId], references: [id])

  @@index([billId, status])
  @@index([vendorId, paymentDate])
  @@index([status, paymentDate])
}

// Vendor credit memo. DRAFT → CONFIRMED → CANCELLED, mirroring
// CreditMemo on the AR side. Lines are simple expense-style
// (description + amount) per pilot scope (Q6 of the discovery).
//
// Auto-creation: overpaying a bill (BillPayment.amount > remaining
// balance) creates a CONFIRMED VendorCredit for the excess, with
// sourceTag = "OVERPAYMENT:<billPaymentId>" for traceability. Manual
// VCs leave sourceTag null.
model VendorCredit {
  id            String             @id @default(cuid())
  number        String             @unique // VCM-YYYY-NNNNN via Sequence
  vendorId      String
  status        VendorCreditStatus @default(DRAFT)
  creditDate    DateTime           @default(now())
  amount        Decimal            @db.Decimal(18, 5)
  // Denormalized counter; recompute helper in the service.
  appliedAmount Decimal            @default(0) @db.Decimal(18, 5)
  currency      String?            @default("USD")
  reason        String?
  notes         String?
  createdById   String?
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  // Origin tag for auto-created credits. Plain text (no FK to BillPayment
  // to avoid cycles). Format: "OVERPAYMENT:<billPaymentId>" or NULL.
  sourceTag     String?
  deletedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  vendor       Vendor                      @relation(fields: [vendorId], references: [id])
  lines        VendorCreditLine[]
  applications VendorCreditApplication[]
  tags         VendorCreditTagAssignment[]

  @@index([vendorId, status])
  @@index([sourceTag])
  @@index([deletedAt])
}

model VendorCreditLine {
  id             String    @id @default(cuid())
  vendorCreditId String
  lineNumber     Int
  description    String
  amount         Decimal   @db.Decimal(18, 5)
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vendorCredit VendorCredit @relation(fields: [vendorCreditId], references: [id])

  @@index([vendorCreditId])
}

// Single source of truth for "this dollar of vendor credit was applied
// to that dollar of bill." Reversed apps are kept (reversedAt set) so
// the audit trail survives. Mirrors CreditApplication on the AR side.
//
// Partial unique index on (vendorCreditId, billId) WHERE reversedAt IS
// NULL prevents multi-applying the same VC to the same bill while live.
// Created in raw SQL in the migration since Prisma can't express
// partial indices.
model VendorCreditApplication {
  id             String    @id @default(cuid())
  vendorCreditId String
  billId         String
  amount         Decimal   @db.Decimal(18, 5)
  appliedAt      DateTime  @default(now())
  appliedById    String?
  reversedAt     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vendorCredit VendorCredit @relation(fields: [vendorCreditId], references: [id])
  bill         Bill         @relation(fields: [billId], references: [id])

  @@index([billId, reversedAt])
  @@index([vendorCreditId])
}

// =========================================================================
// PO shipment tracking + PO direct payments — phase 6 extension.
// Spec: feature brief "PO Shipment Tracking + PO Direct Payments".
//
// Two parallel concerns layered on top of the existing PO lifecycle
// (Draft → Confirmed → PartiallyReceived → Closed), neither of which
// changes that lifecycle:
//
//   PoShipment   — physical-logistics tracking. Many shipments per PO,
//                  each with its own carrier / tracking / ETA + a status
//                  (PAID → IN_PRODUCTION → IN_TRANSIT → DELIVERED). No GL
//                  or inventory effect — receiving is still the Receipt
//                  flow. The PO header shows a rolled-up status.
//
//   PoPayment    — money paid directly against a PO before a bill exists
//                  (prepay / import deposits). Records a cash-out:
//                  DR 1510 Vendor Deposits / CR <cashAccount>. When a bill
//                  later auto-confirms from a receipt on the PO, unapplied
//                  deposits auto-apply oldest-first (DR 2010 AP / CR 1510)
//                  via PoPaymentApplication rows — mirroring the
//                  VendorCredit ↔ VendorCreditApplication architecture.
// =========================================================================

enum PoShipmentStatus {
  PAID
  IN_PRODUCTION
  IN_TRANSIT
  DELIVERED
}

model PoShipment {
  id               String           @id @default(cuid())
  purchaseOrderId  String
  shipmentStatus   PoShipmentStatus @default(IN_PRODUCTION)
  trackingNumber   String?
  carrierName      String?
  trackingUrl      String?
  cartonCount      Int?
  totalWeight      Decimal?         @db.Decimal(18, 5)
  weightUnit       String           @default("lbs")
  estimatedArrival DateTime?
  notes            String?
  createdById      String?
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([deletedAt])
}

// A money-leaving event recorded directly against a PO (prepay / import
// deposit), before any Bill exists. Mirrors BillPayment but credits a
// deposit ASSET (1510 Vendor Deposits) instead of relieving AP. The
// deposit is later consumed against bills via PoPaymentApplication rows.
//
// status / reversedAt mirror BillPayment: a void keeps the row (REVERSED)
// rather than hard-deleting, preserving the audit + GL trail. appliedAmount
// is a denorm of SUM(non-reversed applications.amount); a deposit is
// "fully applied" when appliedAmount == amount.
model PoPayment {
  id              String         @id @default(cuid())
  number          String         @unique // POPMT-YYYY-NNNNN via Sequence
  purchaseOrderId String
  // Denorm for vendor-deposit-history queries without a PO join.
  vendorId        String
  paymentDate     DateTime       @default(now())
  amount          Decimal        @db.Decimal(18, 5)
  // Nullable (a deposit may be logged before the method is known). Reuses
  // the PaymentMethod enum for consistency with BillPayment / Payment.
  method          PaymentMethod?
  // Bank/asset (or credit-card liability) account the deposit was paid
  // from. FK to GlAccount; service validates type ∈ {ASSET, LIABILITY}.
  cashAccountId   String?
  reference       String? // check #, wire ref, ACH trace, etc.
  notes           String?
  status          PaymentStatus  @default(RECORDED)
  // SUM of non-reversed PoPaymentApplication.amount. Recompute helper in
  // the service. isApplied is derived (appliedAmount > 0).
  appliedAmount   Decimal        @default(0) @db.Decimal(18, 5)
  // Convenience pointer to the deposit JE (the DR 1510 / CR cash post).
  // The reversal + application JEs are found via (entityType, entityId).
  journalEntryId  String?
  reversedAt      DateTime?
  reversedReason  String?
  createdById     String?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  purchaseOrder PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id])
  vendor        Vendor                 @relation(fields: [vendorId], references: [id])
  cashAccount   GlAccount?             @relation(fields: [cashAccountId], references: [id])
  journalEntry  JournalEntry?          @relation(fields: [journalEntryId], references: [id])
  applications  PoPaymentApplication[]

  @@index([purchaseOrderId, status])
  @@index([vendorId, paymentDate])
  @@index([status, paymentDate])
  @@index([deletedAt])
}

// Single source of truth for "this dollar of PO deposit was applied to
// that dollar of bill." Mirrors VendorCreditApplication. Reversed apps are
// kept (reversedAt set). Auto-created at receipt time when a bill confirms
// on a PO carrying unapplied deposits; unwound when a deposit is voided.
model PoPaymentApplication {
  id          String    @id @default(cuid())
  poPaymentId String
  billId      String
  amount      Decimal   @db.Decimal(18, 5)
  appliedAt   DateTime  @default(now())
  appliedById String?
  reversedAt  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  poPayment PoPayment @relation(fields: [poPaymentId], references: [id])
  bill      Bill      @relation(fields: [billId], references: [id])

  @@index([billId, reversedAt])
  @@index([poPaymentId])
}

// =========================================================================
// GL period close — phase 9 slice A. Spec: docs/08-gl-costing-reporting.md.
//
// Pilot scope: monthly periods only. Quarterly/yearly aggregations are
// computed at report time from monthly data — no separate records.
//
// Lifecycle:
//   OPEN         — accepts JE posts freely.
//   SOFT_CLOSED  — still accepts posts (per Q4 sign-off; permission
//                  layer will tighten later). Marks the month as
//                  "closed for normal users."
//   HARD_CLOSED  — assertPostingAllowedTx blocks posts unless caller
//                  supplies an override with reason. Override fires a
//                  MANUAL_JE_POSTED audit row tied to the period.
//
// Auto-creation: getOrCreatePeriodForDate creates a period the first
// time a JE is posted into that month. UPSERT on the unique `code` is
// race-safe.
//
// Reconciliation: PeriodReconciliationCheck rows are persisted snapshots
// of the slice-D recon results at close time. Row-per-check, JSON
// details for bucket-level numbers. Live re-runs append fresh rows
// rather than mutating prior ones — append-only audit trail.
// =========================================================================

enum FiscalPeriodStatus {
  OPEN
  SOFT_CLOSED
  HARD_CLOSED
}

model FiscalPeriod {
  id           String             @id @default(cuid())
  // YYYY-MM, e.g., "2026-04". Unique by code; service derives this from
  // a Date via UTC year/month components.
  code         String             @unique
  // Inclusive start, exclusive end. e.g., 2026-04 → start 2026-04-01T00Z,
  // end 2026-05-01T00Z. Half-open interval lets postedAt < endDate be
  // the canonical containment check.
  startDate    DateTime
  endDate      DateTime
  status       FiscalPeriodStatus @default(OPEN)
  // Set on the most recent close transition (soft or hard). Cleared on
  // reopen. Use the audit log for full close/reopen history.
  closedAt     DateTime?
  closedById   String?
  reopenedAt   DateTime?
  reopenedById String?
  reopenReason String?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  reconChecks PeriodReconciliationCheck[]

  @@index([status])
  @@index([startDate])
}

model PeriodReconciliationCheck {
  id               String   @id @default(cuid())
  fiscalPeriodId   String
  // Stable string key. Slice D defines the canonical set:
  //   AR_CONTROL, AP_CONTROL, INVENTORY_<warehouseCode>, CASH,
  //   ACCRUED_RECEIPTS. Per-warehouse INVENTORY checks fan out at
  //   runtime, hence string rather than enum.
  checkType        String
  glBalance        Decimal  @db.Decimal(18, 5)
  subledgerBalance Decimal  @db.Decimal(18, 5)
  difference       Decimal  @db.Decimal(18, 5)
  passed           Boolean
  // Bucket-level numbers, aged rows, etc. Schema-less by design —
  // each checkType writes its own shape. Read with care.
  details          Json?
  checkedAt        DateTime @default(now())

  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id])

  @@index([fiscalPeriodId, checkedAt])
}

// =============================================================================
// Work Orders (Build / Assembly)
// -----------------------------------------------------------------------------
// A WorkOrder records the intent to build N finished units of a parent
// product from its BOM components. The lifecycle is:
//
//   DRAFT  → IN_PROGRESS (manual Start; BOM + labor snapshot are frozen)
//   IN_PROGRESS → IN_PROGRESS (each Complete event consumes components,
//                              produces finished good FIFO layer, posts JE;
//                              partial completions keep status IN_PROGRESS)
//   IN_PROGRESS → COMPLETED  (when qtyCompleted == qtyToBuild)
//   DRAFT or IN_PROGRESS → CANCELLED  (manual, reason required)
//
// BOM and labor are SNAPSHOTTED at create time (WorkOrderComponent +
// WorkOrder.laborCost). Subsequent BOM edits on the parent product don't
// affect open WOs.
//
// laborCost is per finished unit. Editable while DRAFT; frozen on Start.
// =============================================================================
model WorkOrder {
  id           String          @id @default(cuid())
  number       String          @unique // WO-YYYY-NNNNN via Sequence
  productId    String
  // The variant of the assembled product that the finished units land
  // on. Required — every variant has its own FIFO layers + inventory.
  variantId    String
  warehouseId  String
  qtyToBuild   Decimal         @db.Decimal(18, 5)
  qtyCompleted Decimal         @default(0) @db.Decimal(18, 5)
  // Per-unit labor cost rolled into each built unit's FIFO layer.
  // Snapshotted from Product.bomLaborCost at WO creation; editable
  // until status leaves DRAFT.
  laborCost    Decimal?        @db.Decimal(18, 5)
  status       WorkOrderStatus @default(DRAFT)
  notes        String?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  createdById  String?
  deletedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  product     Product                  @relation("WorkOrderProduct", fields: [productId], references: [id])
  variant     ProductVariant           @relation("WorkOrderFinishedVariant", fields: [variantId], references: [id])
  warehouse   Warehouse                @relation(fields: [warehouseId], references: [id])
  components  WorkOrderComponent[]
  completions WorkOrderCompletion[]
  tags        WorkOrderTagAssignment[]

  @@index([productId])
  @@index([status])
  @@index([warehouseId])
  @@index([deletedAt])
}

// BOM snapshot at WO creation. qtyRequiredPerUnit mirrors the source
// BomLine; the total qty consumed at completion = qtyRequiredPerUnit *
// qtyToComplete for that event. Snapshotting keeps the build spec
// stable even if the parent product's live BOM changes mid-WO.
model WorkOrderComponent {
  id                 String   @id @default(cuid())
  workOrderId        String
  componentVariantId String
  qtyRequiredPerUnit Decimal  @db.Decimal(18, 5)
  sortOrder          Int      @default(0)
  notes              String?
  createdAt          DateTime @default(now())

  workOrder        WorkOrder      @relation(fields: [workOrderId], references: [id])
  componentVariant ProductVariant @relation("WorkOrderComponentVariant", fields: [componentVariantId], references: [id])

  @@index([workOrderId, sortOrder])
  @@index([componentVariantId])
}

// One row per Complete event. Partial builds create N rows over the
// life of the WO; each captures the qty completed, the per-unit FIFO
// cost rolled up at that moment, the total labor expense booked, the
// produced FIFO layer (1:1), and the posted JE. Audit-friendly trail
// of "I built 3 on day 1, then 4 on day 5".
model WorkOrderCompletion {
  id              String   @id @default(cuid())
  workOrderId     String
  qtyCompleted    Decimal  @db.Decimal(18, 5)
  unitCost        Decimal  @db.Decimal(18, 5)
  totalLaborCost  Decimal  @db.Decimal(18, 5)
  // 1:1 with the BUILD_PRODUCE FifoLayer this event created. Unique
  // both directions so a layer is owned by exactly one completion.
  producedLayerId String?  @unique
  journalEntryId  String?
  createdById     String?
  createdAt       DateTime @default(now())

  workOrder     WorkOrder     @relation(fields: [workOrderId], references: [id])
  producedLayer FifoLayer?    @relation(fields: [producedLayerId], references: [id])
  journalEntry  JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([workOrderId])
}

// =============================================================================
// Shopify → ERP order sync. Imports park here when the customer match is
// ambiguous (same email, different Shopify customer.id; multiple ERP customers
// share the email) OR when a line_item.sku doesn't resolve to a ProductVariant.
// An operator resolves each pending review from /admin/pending-orders by
// choosing "use existing customer", "create new customer", or "dismiss" — at
// which point the importer re-runs the order under the chosen path and the
// SalesOrder lands like a normal Shopify import.
//
// shopifyOrderData stores the FULL Shopify order payload (line items, addresses,
// transactions, etc.) so the operator can see exactly what's being imported and
// the resolve action can re-build the import without re-fetching from Shopify.
// =============================================================================

enum PendingOrderReviewStatus {
  PENDING
  RESOLVED_EXISTING // operator picked an existing ERP customer; order imported
  RESOLVED_NEW // operator forced new-customer creation; order imported
  DISMISSED // operator decided to ignore; no order imported
}

enum PendingOrderReviewReason {
  // Same email exists on one ERP customer but with a different
  // shopifyCustomerId already set — could be a returning B2B customer
  // who later created a separate B2C account, or a fraudster.
  EMAIL_MATCH_DIFFERENT_ID
  // Multiple ERP customers share this email — common for franchise
  // owners with several locations under one contact email.
  MULTIPLE_EMAIL_MATCHES
  // Email matched exactly one ERP customer but no store-scoped
  // ShopifyCustomerLink exists yet. Queued for operator review so they
  // can confirm the match or create a separate billing account — important
  // for B2B customers with multiple store locations sharing one email.
  EMAIL_MATCH_NO_STORE_LINK
  // line_item.sku didn't resolve to any active ProductVariant. Operator
  // either maps the SKU to an existing variant (future) or creates the
  // product upstream and re-runs.
  UNKNOWN_SKU
}

model PendingOrderReview {
  id                   String                   @id @default(cuid())
  shopifyStoreId       String
  shopifyOrderId       String
  shopifyOrderNumber   String
  shopifyCustomerEmail String
  shopifyCustomerId    String?
  // Full Shopify order payload as returned by orders.json. Used by the
  // review UI to render the side-by-side comparison and by the resolve
  // action to re-run the import without re-fetching from Shopify.
  shopifyOrderData     Json
  reason               PendingOrderReviewReason
  // For email-match cases: the single ERP customer the email pointed at.
  // For multiple-email-match cases: null (the UI shows the list inline).
  // For unknown-SKU cases: null (no customer match issue at all).
  matchedCustomerId    String?
  // For unknown-SKU cases: the offending line_item.sku so the UI can
  // highlight it. Null for customer-match cases.
  unknownSku           String?
  status               PendingOrderReviewStatus @default(PENDING)
  resolvedAt           DateTime?
  resolvedById         String?
  // When status=RESOLVED_*, the SalesOrder.id the resolve action produced.
  // Null on PENDING / DISMISSED rows.
  resolvedSalesOrderId String?
  notes                String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  store           ShopifyStore @relation(fields: [shopifyStoreId], references: [id])
  matchedCustomer Customer?    @relation("PendingOrderReviewMatchedCustomer", fields: [matchedCustomerId], references: [id])

  // (shopifyStoreId, shopifyOrderId) is unique among PENDING rows so a
  // webhook re-fire doesn't queue a duplicate review. Resolved/dismissed
  // rows stay in history. Service-layer guard.
  @@index([shopifyStoreId, shopifyOrderId])
  @@index([status, createdAt])
  @@index([matchedCustomerId])
}
