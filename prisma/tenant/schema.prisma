generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

enum ProductType {
  SIMPLE
  DROP_SHIP
  SERVICE
}

enum InventoryMovementType {
  ADJUST
  RECEIVE
  CONSUME
  TRANSFER_OUT
  TRANSFER_IN
  RECEIVE_REVERSE
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  CLOSED
  CANCELLED
}

enum ReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  VOID
  REVERSE
  REFUND
  PERMISSION_CHANGE
  CONFIG_CHANGE
  LOGIN
  LOGOUT
  INSUFFICIENT_STOCK_AT_CLOSE
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  DISPATCHED
  CLOSED
  CANCELLED
}

enum SalesOrderSource {
  STAFF
  PORTAL
  SHOPIFY
}

// Which rule fired in the pricing resolver for a given line. In pilot only
// BASE_PRICE and MANUAL_OVERRIDE are wired; the other rules land alongside
// the customer master + promo + qty-break + cost-plus slices.
enum PriceResolutionRule {
  BASE_PRICE
  MANUAL_OVERRIDE
  CUSTOMER_SPECIFIC
  QTY_BREAK
  TIER_DISCOUNT
  PROMO
  COST_PLUS
}

model Product {
  id               String      @id @default(cuid())
  sku              String      @unique
  name             String
  shortDescription String?
  longDescription  String?
  brand            String?
  category         String?
  type             ProductType @default(SIMPLE)
  tracksInventory  Boolean     @default(true)
  basePrice        Decimal?    @db.Decimal(18, 5)
  weight           Decimal?    @db.Decimal(18, 5)
  lengthDim        Decimal?    @db.Decimal(18, 5)
  widthDim         Decimal?    @db.Decimal(18, 5)
  heightDim        Decimal?    @db.Decimal(18, 5)
  shopifyProductId String?
  active           Boolean     @default(true)
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  variants ProductVariant[]

  @@index([category])
  @@index([brand])
  @@index([shopifyProductId])
}

model ProductVariant {
  id           String    @id @default(cuid())
  productId    String
  sku          String    @unique
  name         String?
  variantGroup String?
  color        String?
  flavor       String?
  size         String?
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product            Product             @relation(fields: [productId], references: [id])
  inventory          InventoryItem[]
  movements          InventoryMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  receiptLines       ReceiptLine[]
  salesOrderLines    SalesOrderLine[]

  @@index([productId])
}

model Warehouse {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  inventory          InventoryItem[]
  movements          InventoryMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  receipts           Receipt[]
  receiptLines       ReceiptLine[]
  salesOrders        SalesOrder[]
  salesOrderLines    SalesOrderLine[]
}

model InventoryItem {
  id          String   @id @default(cuid())
  variantId   String
  warehouseId String
  onHand      Decimal  @default(0) @db.Decimal(18, 5)
  reserved    Decimal  @default(0) @db.Decimal(18, 5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])

  @@unique([variantId, warehouseId])
  @@index([warehouseId])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  variantId       String
  warehouseId     String
  type            InventoryMovementType
  qty             Decimal               @db.Decimal(18, 5)
  reference       String?
  transferGroupId String?
  notes           String?
  createdById     String?
  createdAt       DateTime              @default(now())

  variant     ProductVariant @relation(fields: [variantId], references: [id])
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  receiptLine ReceiptLine?

  @@index([variantId, warehouseId, createdAt])
  @@index([type, createdAt])
  @@index([reference])
  @@index([transferGroupId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  beforeJson Json?
  afterJson  Json?
  reason     String?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// Generic monotonic sequence with optional annual reset. Allocate via
// SELECT ... FOR UPDATE inside a transaction (lib/sequences/sequences.ts).
// Reused by PO numbering, Receipt numbering, and (later) Bill, SO, Invoice.
model Sequence {
  name         String   @id
  currentValue Int      @default(0)
  year         Int?
  updatedAt    DateTime @updatedAt
}

// Minimal vendor stub. Full Vendor master (contacts, payment methods, terms,
// drop-ship/stock flags, commission rate, shadow-customer link, etc.) lands
// in its own slice (see docs/04-vendors-purchasing.md). For now POs and
// Receipts need *something* to FK against — this row holds the bare minimum.
// EXPAND LATER.
model Vendor {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]
  receipts       Receipt[]
}

model PurchaseOrder {
  id                  String              @id @default(cuid())
  number              String              @unique
  vendorId            String
  status              PurchaseOrderStatus @default(DRAFT)
  expectedReceiveDate DateTime?
  currency            String?             @default("USD")
  notes               String?
  createdById         String?
  confirmedAt         DateTime?
  closedAt            DateTime?
  cancelledAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  vendor Vendor              @relation(fields: [vendorId], references: [id])
  lines  PurchaseOrderLine[]

  @@index([vendorId, status])
  @@index([status, expectedReceiveDate])
  @@index([deletedAt])
}

model PurchaseOrderLine {
  id                     String    @id @default(cuid())
  purchaseOrderId        String
  variantId              String
  warehouseId            String
  qtyOrdered             Decimal   @db.Decimal(18, 5)
  qtyReceived            Decimal   @default(0) @db.Decimal(18, 5)
  unitCost               Decimal   @db.Decimal(18, 5)
  vendorSku              String?
  manufacturerPartNumber String?
  notes                  String?
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  receiptLines  ReceiptLine[]

  @@index([purchaseOrderId])
  @@index([variantId])
  @@index([warehouseId])
}

model Receipt {
  id          String        @id @default(cuid())
  number      String        @unique
  vendorId    String
  warehouseId String
  status      ReceiptStatus @default(DRAFT)
  receivedAt  DateTime?
  postedById  String?
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor    Vendor        @relation(fields: [vendorId], references: [id])
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  lines     ReceiptLine[]

  @@index([vendorId, status])
  @@index([warehouseId, receivedAt])
  @@index([deletedAt])
}

// PO ↔ Receipt M:N is realized by: many ReceiptLines pointing at one POLine
// (a PO line can be received in multiple shipments) and a single Receipt
// having ReceiptLines pointing at POLines from different POs (one shipment
// covering multiple POs). No separate join table is needed.
model ReceiptLine {
  id                  String    @id @default(cuid())
  receiptId           String
  purchaseOrderLineId String?
  variantId           String
  warehouseId         String
  qtyReceived         Decimal   @db.Decimal(18, 5)
  unitCost            Decimal   @db.Decimal(18, 5)
  inventoryMovementId String?   @unique
  notes               String?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  receipt           Receipt            @relation(fields: [receiptId], references: [id])
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])
  variant           ProductVariant     @relation(fields: [variantId], references: [id])
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id])
  inventoryMovement InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])

  @@index([receiptId])
  @@index([purchaseOrderLineId])
  @@index([variantId, warehouseId])
}

// Minimal customer stub. Full Customer master (contacts, ship-to/bill-to
// addresses, payment terms, tax exemption, sales rep, pricing tier, AR
// balance, portal credentials, etc.) lands in its own slice (see
// docs/03-customers.md). For now Sales Orders need *something* to FK
// against — this row holds the bare minimum. Strict mirror of the Vendor
// stub above. EXPAND LATER.
model Customer {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  salesOrders SalesOrder[]
}

model SalesOrder {
  id                   String           @id @default(cuid())
  number               String           @unique
  customerId           String
  warehouseId          String
  status               SalesOrderStatus @default(DRAFT)
  source               SalesOrderSource @default(STAFF)
  currency             String?          @default("USD")
  customerPo           String?
  promisedShipDate     DateTime?
  orderDate            DateTime         @default(now())
  // Order-level money. Decimal(18,5); rounding happens at display only.
  // discountPercent and discountAmount are mutually exclusive (Zod-enforced).
  orderDiscountPercent Decimal?         @db.Decimal(18, 5)
  orderDiscountAmount  Decimal?         @db.Decimal(18, 5)
  shippingAmount       Decimal?         @db.Decimal(18, 5)
  handlingAmount       Decimal?         @db.Decimal(18, 5)
  // Free-text ship-to for pilot. The customer master slice will replace
  // this with a proper Address relation; intentionally nullable now.
  shippingAddress      String?
  customerNotes        String?
  internalNotes        String?
  createdById          String?
  // Lifecycle timestamps. Per docs/05-sales-orders.md, picked_at /
  // packed_at / shipping_calculated_at / invoice_generated_at /
  // payment_captured_at are flags-not-statuses and land with the
  // pick/pack/invoice workflows in later slices.
  confirmedAt          DateTime?
  dispatchedAt         DateTime?
  closedAt             DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  deletedAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  customer  Customer         @relation(fields: [customerId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  lines     SalesOrderLine[]

  @@index([customerId, status])
  @@index([status, orderDate])
  @@index([warehouseId])
  @@index([deletedAt])
}

model SalesOrderLine {
  id              String              @id @default(cuid())
  salesOrderId    String
  variantId       String
  warehouseId     String
  qtyOrdered      Decimal             @db.Decimal(18, 5)
  qtyReserved     Decimal             @default(0) @db.Decimal(18, 5)
  qtyShipped      Decimal             @default(0) @db.Decimal(18, 5)
  unitPrice       Decimal             @db.Decimal(18, 5)
  priceRule       PriceResolutionRule
  // discountPercent and discountAmount are mutually exclusive (Zod-enforced).
  discountPercent Decimal?            @db.Decimal(18, 5)
  discountAmount  Decimal?            @db.Decimal(18, 5)
  customerNote    String?
  internalNote    String?
  // unitCost snapshot at Closed lands when the costing engine ships
  // (docs/08-gl-costing-reporting.md). Not stored on the line yet.
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  salesOrder SalesOrder     @relation(fields: [salesOrderId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  warehouse  Warehouse      @relation(fields: [warehouseId], references: [id])

  @@index([salesOrderId])
  @@index([variantId, warehouseId])
  @@index([deletedAt])
}
